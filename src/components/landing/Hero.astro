---
import LinkBlend from "@components/global/LinkBlend.astro";
import { getLangFromUrl, useTranslations, useTranslatedPath } from "@i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);
---

<section id="hero" class="section home-dark-section hero min-h-0 lg:min-h-screen">
	<div class="mx-auto flex h-full flex-col py-4 lg:py-10">
		<div class="relative flex flex-1 flex-col justify-start lg:justify-center gap-8 lg:gap-12 rounded-lg pb-10 pt-20 lg:rounded-2xl lg:pt-20">
			<div class="flex flex-col items-center justify-center">
				<div id="hero-lottie" class="h-60 w-60 md:h-80 md:w-80" aria-hidden="true"></div>
				<h1 class="hero-title text-center font-display">
					<span class="inline-block">{t("hero.title.main")}</span>
					<span class="rotator relative inline-flex w-full justify-center">
						<span>{t("hero.title.3")}</span><span>{t("hero.title.4")}</span><span>{t("hero.title.5")}</span><span>{t("hero.title.6")}</span><span>
							{t("hero.title.1")}
						</span><span>{t("hero.title.2")}</span><span>{t("hero.title.3")}</span>
					</span>
				</h1>
			</div>
			<div class="flex flex-col items-center gap-5 text-center lg:gap-10">
				<p class="mt-2 max-w-3xl font-mono lg:text-lg">
					{t("hero.subtitle")}
				</p>
				<div class="flex flex-col items-center justify-center gap-3 lg:col-start-1">
					<div class="squircle-bg rounded-lg !bg-[#F06071]" data-cursor-hover data-cursor-parallax>
						<a
							class="flex h-10 w-full max-w-52 flex-1 items-center justify-center px-4 py-2 text-xl text-slate-200 transition-all hover:text-white sm:w-auto md:font-bold lg:h-10"
							aria-label="Contact Page"
							href={translatePath("/contact/")}>
							{t("contact")}
						</a>
					</div>

					<small>
						{t("or")}
						<button id="go-projects-button" class="underline underline-offset-4 hover:opacity-80 transition-opacity">
							{t("hero.scroll")}
						</button>
					</small>
				</div>
			</div>
		</div>
	</div>
</section>

<style>
	.hero {
		padding-bottom: 0;
		position: relative;
		border-radius: inherit;
		overflow: hidden;
	}
	.hero > div {
		grid-column: 1 / span 12;
	}

	/* Hero appearance */
	.hero h1,
	.hero h2,
	.hero h3 {
		margin: 0;
	}
	.hero h1 {
		margin: 0;
		position: relative;
	}
	.hero h1 > div {
		position: relative;
		margin: 0;
	}
	.hero :global(.split-parent) {
		overflow: hidden;
	}
	.hero :global(.split-child) {
		display: inline-block;
	}

	/* Hero title responsive sizing */
	.hero-title {
		font-size: clamp(1.8rem, 7vw, 8rem);
		line-height: 1.1;
	}

	/* Text rotator */
	.rotator {
		height: clamp(2.2rem, 9vw, 9rem);
	}

	.rotator > span {
		position: absolute;
	}

	.rotator > span:not(:nth-child(1)) {
		opacity: 0;
	}

	/* Hero entrance — pure CSS, fires immediately, no JS dependency.
	   We don't override `display` here: the spans already carry `inline-block`
	   and `inline-flex` from the markup, both of which accept transforms. */
	.hero h1 > span {
		animation: hero-rise 1.2s cubic-bezier(0.16, 1, 0.3, 1) both;
		will-change: transform, opacity;
	}
	.hero h1 > span:nth-child(2) { animation-delay: 0.1s; }

	@keyframes hero-rise {
		from { transform: translateY(100%); opacity: 0; }
		to   { transform: translateY(0);    opacity: 1; }
	}

	/* Lottie canvas: invisible until the player loads and animates it in */
	#hero-lottie {
		transform: scale(0);
		transform-origin: center;
		will-change: transform;
	}

	@media (prefers-reduced-motion: reduce) {
		.hero h1 > span { animation: none; }
		#hero-lottie { transform: none; }
	}
</style>

<script>
	import { gsap } from "gsap";
	import { ScrollTrigger } from "gsap/ScrollTrigger";
	import { ScrollToPlugin } from "gsap/ScrollToPlugin";

	gsap.registerPlugin(ScrollTrigger, ScrollToPlugin);

	const ENTRANCE_MS = 1300; // matches CSS hero-rise (1.2s) + last stagger (0.1s)

	function startRotator() {
		const words = document.querySelectorAll(".hero .rotator > span");
		if (!words.length) return;

		const rotatorTimeline = gsap.timeline({ repeat: -1 });
		rotatorTimeline.timeScale(0.5);

		for (let i = 0; i < words.length; i++) {
			let delay = i - 1;
			const wordTL = gsap.timeline();
			if (i !== 0) {
				gsap.set(words[i], { opacity: 1 });
				wordTL.from(words[i], { duration: 1, yPercent: 100, opacity: 0, ease: "power4.out" });
			} else {
				delay += 1;
				gsap.set(words[0], { opacity: 1, yPercent: 0 });
			}
			if (i !== words.length - 1) {
				wordTL.to(words[i], { duration: 1, opacity: 0, ease: "power4.out" });
			}
			rotatorTimeline.add(wordTL, delay);
		}
	}

	async function initLottie() {
		const container = document.getElementById("hero-lottie");
		if (!container) return;

		// Code-split: lottie-web is fetched only when the browser is idle
		const lottie = (await import("lottie-web/build/player/lottie_light")).default;

		const player = lottie.loadAnimation({
			container,
			renderer: "svg", // vector → crisp at any DPR / any scale
			loop: true,
			autoplay: false,
			path: "/animation2-ia.json",
			rendererSettings: {
				preserveAspectRatio: "xMidYMid meet",
				progressiveLoad: true,
			},
		});

		player.addEventListener("DOMLoaded", () => {
			gsap.to(container, {
				scale: 1,
				duration: 1.5,
				ease: "elastic.out(1, 0.75)",
				onComplete: () => player.play(),
			});
		});
	}

	function init() {
		// Words rotate as soon as the CSS entrance finishes — independent of Lottie
		setTimeout(startRotator, ENTRANCE_MS);

		// Lottie loads off the critical path (after first paint / when browser is idle)
		const loadLottie = () => initLottie();
		if ("requestIdleCallback" in window) {
			(window as any).requestIdleCallback(loadLottie, { timeout: 800 });
		} else {
			setTimeout(loadLottie, 200);
		}

		const goProjectsButton = document.getElementById("go-projects-button");
		goProjectsButton?.addEventListener("click", () => {
			gsap.to(window, { duration: 0.5, scrollTo: "#projects" });
		});
	}

	if (document.readyState === "loading") {
		document.addEventListener("DOMContentLoaded", init);
	} else {
		init();
	}
</script>
