---
const pathname = Astro.url.pathname;
const isBlog = pathname.includes('/blog') || pathname.includes('/posts');

const footerBg = isBlog ? "bg-slate-50" : "bg-zinc-900";
const textColor = isBlog ? "text-zinc-900" : "text-white";
const iconColor = isBlog ? "text-[#F06071]" : "text-[#d4eb28]";
const iconHover = isBlog ? "hover:text-black" : "hover:text-white";
const goTopColor = isBlog ? "text-zinc-900 hover:fill-zinc-900 hover:text-white" : "text-white hover:fill-white hover:text-black";
