	<!-- Scroll Top Button -->
	<div class="absolute bottom-4 right-4 lg:bottom-10 lg:right-10">
		<button
			id="go-top-button"
			aria-label="Go to Top"
			class:list={["fill-transparent transition-colors duration-300", goTopColor]}
			data-cursor-hover
			data-cursor-parallax>
			<svg xmlns="http://www.w3.org/2000/svg" width="50" height="50" viewBox="0 0 24 24">
				<g stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5">
					<circle cx="12" cy="12" r="9"></circle><path d="m15 12l-3-3m0 0l-3 3m3-3v6"></path>
				</g>
			</svg>
		</button>
