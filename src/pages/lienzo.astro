const titleColorHex         = document.getElementById('titleColorHex');
const titleLine2Input       = document.getElementById('titleLine2Input');
const titleLine2ColorInput  = document.getElementById('titleLine2ColorInput');
const titleLine2ColorSwatch = document.getElementById('titleLine2ColorSwatch');
const titleLine2ColorHex    = document.getElementById('titleLine2ColorHex');
