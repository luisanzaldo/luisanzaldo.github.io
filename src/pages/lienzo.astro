  metarrelato: { metaTitleColor: '#CCFF00', metaBodyColor: '#CCFF00', logoColor: '#CCFF00', logoPosition: 'top-left' },
};

const state = {
  image: null,
  imgW: 0,
  imgH: 0,
  cropOffsetX: 0,
  cropOffsetY: 0,
  align: { h: 'left', v: 'bottom' },
  activeTemplate: 'rutadorada',
  title: '',
  titleColor: '#E8B800',
  titleLine2: '',
  titleLine2Color: '#ffffff',
  subtitle: '',
  subtitleColor: '#E8B800',
  dividerColor: '#E8B800',
  // metarrelato-specific
  metaTitle: '',
  metaTitleColor: '#CCFF00',
  metaBody: '',
  metaBodyColor: '#CCFF00',
  logoColor: '#CCFF00',
  logoPosition: 'top-left',
};

