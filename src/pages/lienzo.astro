// ============================================================
// IMAGE UPLOAD
// ============================================================
function setupUpload() {
  uploadState.addEventListener('click', () => fileInput.click());
  changeImageBtn.addEventListener('click', () => fileInput.click());

  fileInput.addEventListener('change', (e) => {
    if (e.target.files[0]) loadImage(e.target.files[0]);
  });

  uploadState.addEventListener('dragover', (e) => {
    e.preventDefault();
    uploadState.classList.add('border-primary', 'bg-primary/5');
  });
  uploadState.addEventListener('dragleave', () => {
    uploadState.classList.remove('border-primary', 'bg-primary/5');
  });
  uploadState.addEventListener('drop', (e) => {
    e.preventDefault();
    uploadState.classList.remove('border-primary', 'bg-primary/5');
    const file = e.dataTransfer.files[0];
    if (file && file.type.startsWith('image/')) loadImage(file);
  });
}

function loadImage(file) {
  const url = URL.createObjectURL(file);
  const img = new Image();
  img.onload = () => {
    state.image = img;
    state.imgW = img.naturalWidth;
    state.imgH = img.naturalHeight;
    state.cropOffsetX = 0;
    state.cropOffsetY = 0;
    resetGenerateBtn();

    previewImg.src = url;
    uploadState.classList.add('hidden');
    canvasState.classList.remove('hidden');

    requestAnimationFrame(() => {
      requestAnimationFrame(() => {
        setupCropRect();
        updatePreview();
      });
    });
  };
  img.src = url;
}

// ============================================================
// CROP GEOMETRY
// ============================================================
function getImageDisplayBounds() {
  const cW = canvasWrapper.clientWidth;
  const cH = canvasWrapper.clientHeight;
  const imgAspect = state.imgW / state.imgH;
  const cAspect = cW / cH;

  let dispW, dispH, dispX, dispY;
  if (imgAspect > cAspect) {
    dispW = cW;
    dispH = cW / imgAspect;
    dispX = 0;
    dispY = (cH - dispH) / 2;
  } else {
    dispH = cH;
    dispW = cH * imgAspect;
    dispX = (cW - dispW) / 2;
    dispY = 0;
  }
  return { dispW, dispH, dispX, dispY };
}

function getCropDisplaySize() {
  const { dispW, dispH } = getImageDisplayBounds();
  const CROP_ASPECT = 9 / 16;
  const imgAspect = state.imgW / state.imgH;

  let cropW, cropH;
  if (imgAspect >= CROP_ASPECT) {
    // Image wider than 9:16 → crop height = full image height
    cropH = dispH;
    cropW = dispH * CROP_ASPECT;
  } else {
    // Image taller → crop width = full image width
    cropW = dispW;
    cropH = dispW / CROP_ASPECT;
    if (cropH > dispH) {
      cropH = dispH;
      cropW = dispH * CROP_ASPECT;
    }
  }
  return { cropW, cropH };
}

function clampCropOffset() {
  const { dispW, dispH } = getImageDisplayBounds();
  const { cropW, cropH } = getCropDisplaySize();
  state.cropOffsetX = Math.max(0, Math.min(state.cropOffsetX, dispW - cropW));
  state.cropOffsetY = Math.max(0, Math.min(state.cropOffsetY, dispH - cropH));
}

function setupCropRect() {
  const { dispX, dispY } = getImageDisplayBounds();
  const { cropW, cropH } = getCropDisplaySize();
  clampCropOffset();
  cropRect.style.width  = `${cropW}px`;
  cropRect.style.height = `${cropH}px`;
  cropRect.style.left   = `${dispX + state.cropOffsetX}px`;
  cropRect.style.top    = `${dispY + state.cropOffsetY}px`;
}

// ============================================================
// CROP DRAG
// ============================================================
let dragging = false;
let dragStartX, dragStartY, dragStartOffX, dragStartOffY;

function setupCropDrag() {
  cropRect.addEventListener('mousedown', (e) => {
    dragging = true;
    dragStartX = e.clientX;
    dragStartY = e.clientY;
    dragStartOffX = state.cropOffsetX;
    dragStartOffY = state.cropOffsetY;
    e.preventDefault();
  });

  cropRect.addEventListener('touchstart', (e) => {
    const t = e.touches[0];
    dragging = true;
    dragStartX = t.clientX;
    dragStartY = t.clientY;
    dragStartOffX = state.cropOffsetX;
    dragStartOffY = state.cropOffsetY;
    e.preventDefault();
  }, { passive: false });

  document.addEventListener('mousemove', (e) => {
    if (!dragging) return;
    state.cropOffsetX = dragStartOffX + (e.clientX - dragStartX);
    state.cropOffsetY = dragStartOffY + (e.clientY - dragStartY);
    clampCropOffset();
    setupCropRect();
  });

  document.addEventListener('touchmove', (e) => {
    if (!dragging) return;
    const t = e.touches[0];
    state.cropOffsetX = dragStartOffX + (t.clientX - dragStartX);
    state.cropOffsetY = dragStartOffY + (t.clientY - dragStartY);
    clampCropOffset();
    setupCropRect();
  }, { passive: false });

  document.addEventListener('mouseup',  () => { dragging = false; });
  document.addEventListener('touchend', () => { dragging = false; });
}

// ============================================================
// PREVIEW TEXT
// ============================================================
function escapeHtml(s) {
  return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
}


function updatePreview() {
  if (!state.image) return;

  const { cropW, cropH } = getCropDisplaySize();
  const scale = cropW / 1080;

  if (state.activeTemplate === 'metarrelato') {
    updatePreviewMetarrelato(scale, cropW, cropH);
  } else {
    updatePreviewRutadorada(scale);
  }
}

function updatePreviewRutadorada(scale) {
  const isLeft   = state.align.h === 'left';
  const isBottom = state.align.v === 'bottom';
  const padX = 72 * scale;
  const padY = 180 * scale;
  const tb = previewTextBlock;
  tb.style.left      = isLeft   ? `${padX}px` : 'auto';
  tb.style.right     = isLeft   ? 'auto' : `${padX}px`;
  tb.style.bottom    = isBottom ? `${padY}px` : 'auto';
  tb.style.top       = isBottom ? 'auto' : `${padY}px`;
  tb.style.textAlign = isLeft   ? 'left' : 'right';
  tb.style.maxWidth  = `calc(100% - ${padX * 2}px)`;

  const divDir = isLeft ? 'to right' : 'to left';
  const hasAny = state.title || state.titleLine2 || state.subtitle;
  let html = '';
  if (state.title) {
    html += `<span class="preview-title-main" style="font-size:${196*scale}px;color:${state.titleColor};margin-bottom:${12*scale}px">${escapeHtml(state.title)}</span>`;
  }
  if (state.titleLine2) {
    html += `<span class="preview-title-sub" style="font-size:${96*scale}px;color:${state.titleLine2Color};margin-bottom:${28*scale}px;display:block">${escapeHtml(state.titleLine2)}</span>`;
  } else if (state.title) {
    html += `<div style="height:${28*scale}px"></div>`;
  }
  if (hasAny) {
    const dc = state.dividerColor;
    const dcAlpha = hexToRgba(dc, 0.2);
    html += `<div style="height:${2*scale}px;background:linear-gradient(${divDir},${dc},${dcAlpha},transparent);margin-bottom:${24*scale}px"></div>`;
  }
  if (state.subtitle) {
    html += `<span class="preview-subtitle" style="font-size:${72*scale}px;color:${state.subtitleColor}">${escapeHtml(state.subtitle)}</span>`;
  }
  tb.innerHTML = html;
  previewLogoBlock.style.display = 'none';
}

function updatePreviewMetarrelato(scale, cropW, cropH) {
  const isLeft   = state.align.h === 'left';
  const isBottom = state.align.v === 'bottom';
  const padLeft   = 80 * scale;
  const padRight  = 120 * scale;
  const padBottom = 160 * scale;
  const padTop    = 50 * scale;

  // Text block
  const tb = previewTextBlock;
  tb.style.left      = isLeft ? `${padLeft}px` : 'auto';
  tb.style.right     = isLeft ? 'auto' : `${padRight}px`;
  tb.style.bottom    = isBottom ? `${padBottom}px` : 'auto';
  tb.style.top       = isBottom ? 'auto' : `${padTop + 144 * scale + 24 * scale}px`;
  tb.style.textAlign = isLeft ? 'left' : 'right';
  tb.style.maxWidth  = `${cropW - padLeft - padRight}px`;

  const TITLE_SIZE = 148 * scale;
  const BODY_SIZE  = 44  * scale;
  const BODY_LH    = BODY_SIZE * 1.53;

  let html = '';
  if (state.metaTitle) {
    html += `<div style="font-family:'Roboto',sans-serif;font-weight:900;font-size:${TITLE_SIZE}px;line-height:0.92;letter-spacing:-${2*scale}px;color:${state.metaTitleColor};text-transform:lowercase;margin-bottom:${16*scale}px">${escapeHtml(state.metaTitle)}</div>`;
  }
  if (state.metaBody) {
    html += `<div style="font-family:'Roboto',sans-serif;font-weight:400;font-size:${BODY_SIZE}px;line-height:${BODY_LH}px;letter-spacing:${0.5*scale}px;color:${state.metaBodyColor};word-break:break-word">${escapeHtml(state.metaBody)}</div>`;
  }
  tb.innerHTML = html;

  // Logo
  const LOGO_H = 144 * scale;
  const LOGO_W = LOGO_H; // square viewBox
  const lb = previewLogoBlock;
  lb.style.display = 'block';
  lb.style.width   = `${LOGO_W}px`;
  lb.style.height  = `${LOGO_H}px`;

  switch (state.logoPosition) {
    case 'top-left':     lb.style.left = `${80*scale}px`;  lb.style.top = `${50*scale}px`;  lb.style.right = 'auto'; lb.style.bottom = 'auto'; break;
    case 'top-right':    lb.style.right = `${80*scale}px`; lb.style.top = `${50*scale}px`;  lb.style.left = 'auto';  lb.style.bottom = 'auto'; break;
    case 'bottom-left':  lb.style.left = `${80*scale}px`;  lb.style.bottom = `${80*scale}px`; lb.style.right = 'auto'; lb.style.top = 'auto';   break;
    case 'bottom-right': lb.style.right = `${80*scale}px`; lb.style.bottom = `${80*scale}px`; lb.style.left = 'auto';  lb.style.top = 'auto';   break;
  }
  lb.innerHTML = `<div style="width:${LOGO_W}px;height:${LOGO_H}px;background-color:${state.logoColor};-webkit-mask-image:url('/lienzo/metarrelato-future.svg');mask-image:url('/lienzo/metarrelato-future.svg');-webkit-mask-size:contain;mask-size:contain;-webkit-mask-repeat:no-repeat;mask-repeat:no-repeat;"></div>`;
}

// ============================================================
// HELPERS
function hexToRgba(hex, alpha) {
  const r = parseInt(hex.slice(1,3),16);
  const g = parseInt(hex.slice(3,5),16);
  const b = parseInt(hex.slice(5,7),16);
  return `rgba(${r},${g},${b},${alpha})`;
}

// ============================================================
// COLOR PICKERS
// ============================================================
function setupColorPicker(prefix) {
  const input  = document.getElementById(`${prefix}ColorInput`);
  const swatch = document.getElementById(`${prefix}ColorSwatch`);
  const hexEl  = document.getElementById(`${prefix}ColorHex`);
  const key    = `${prefix}Color`;

  input.addEventListener('input', () => {
    const c = input.value;
    swatch.style.background = c;
    hexEl.textContent = c.toUpperCase();
    state[key] = c;
    updatePreview();
  });
}

// ============================================================
// ALIGNMENT BUTTONS
// ============================================================
function setupAlignment() {
  alignBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const a = btn.dataset.align;
      const isH = a === 'left' || a === 'right';

      alignBtns.forEach(b => {
        const bIsH = b.dataset.align === 'left' || b.dataset.align === 'right';
        if (bIsH === isH) b.classList.remove('active');
      });
      btn.classList.add('active');

      if (isH) state.align.h = a;
      else      state.align.v = a;

      updatePreview();
    });
  });
}

// ============================================================
// TEMPLATE SWITCHING
// ============================================================
function applyTemplate(id) {
  const tpl = TEMPLATES[id];
  if (!tpl) return;
  state.activeTemplate = id;

  const rdPanel   = document.getElementById('controls-rutadorada');
  const metaPanel = document.getElementById('controls-metarrelato');

  if (id === 'metarrelato') {
    // Apply metarrelato defaults to state
    state.metaTitleColor = tpl.metaTitleColor;
    state.metaBodyColor  = tpl.metaBodyColor;
    state.logoColor      = tpl.logoColor;
    state.logoPosition   = tpl.logoPosition;
    // Sync metarrelato color pickers
    metaTitleColorInput.value           = state.metaTitleColor;
    metaTitleColorSwatch.style.background = state.metaTitleColor;
    metaTitleColorHex.textContent       = state.metaTitleColor.toUpperCase();
    metaBodyColorInput.value            = state.metaBodyColor;
    metaBodyColorSwatch.style.background  = state.metaBodyColor;
    metaBodyColorHex.textContent        = state.metaBodyColor.toUpperCase();
    // Reset logo selectors
    syncLogoColorBtns();
    syncLogoPosBtns();
    // Show/hide panels
    rdPanel.style.display   = 'none';
    metaPanel.style.display = 'flex';
  } else {
    // Apply rutadorada defaults to state
    state.titleColor     = tpl.titleColor;
    state.titleLine2Color = tpl.titleLine2Color;
    state.subtitleColor  = tpl.subtitleColor;
    state.dividerColor   = tpl.dividerColor;
    // Sync rutadorada color pickers
    ['title', 'titleLine2', 'subtitle'].forEach(prefix => {
      const key    = `${prefix}Color`;
      const input  = document.getElementById(`${prefix}ColorInput`);
      const swatch = document.getElementById(`${prefix}ColorSwatch`);
      const hexEl  = document.getElementById(`${prefix}ColorHex`);
      if (!input) return;
      input.value = state[key];
      swatch.style.background = state[key];
      hexEl.textContent = state[key].toUpperCase();
    });
    // Show/hide panels
    rdPanel.style.display   = 'flex';
    metaPanel.style.display = 'none';
  }

  // Update template button borders + badge
  document.querySelectorAll('.template-btn').forEach(btn => {
    const isActive = btn.dataset.template === id;
    btn.classList.toggle('border-primary', isActive);
    btn.classList.toggle('border-outline-variant/30', !isActive);
    btn.classList.toggle('shadow-md', isActive);
    const badge = btn.querySelector('.tpl-badge');
    if (badge) badge.classList.toggle('hidden', !isActive);
  });

  // Update template label colors
  document.querySelectorAll('[data-tpl-label]').forEach(label => {
    const isActive = label.dataset.tplLabel === id;
    label.classList.toggle('text-primary', isActive);
    label.classList.toggle('text-on-surface-variant', !isActive);
  });

  updatePreview();
}

function syncLogoColorBtns() {
  document.querySelectorAll('.logo-color-btn').forEach(b => {
    const active = b.dataset.color === state.logoColor;
    b.classList.toggle('ring-2', active);
    b.classList.toggle('ring-primary', active);
    b.classList.toggle('ring-offset-1', active);
    b.classList.toggle('ring-offset-surface-container-lowest', active);
  });
}

function syncLogoPosBtns() {
  document.querySelectorAll('.logo-pos-btn').forEach(b => {
    b.classList.toggle('active', b.dataset.pos === state.logoPosition);
  });
}

function setupTemplates() {
  document.querySelectorAll('.template-btn[data-template]').forEach(btn => {
    btn.addEventListener('click', () => applyTemplate(btn.dataset.template));
  });
}

function setupMetaColorPicker(inputId, swatchId, hexId, stateKey) {
  const input  = document.getElementById(inputId);
  const swatch = document.getElementById(swatchId);
  const hexEl  = document.getElementById(hexId);
  input.addEventListener('input', () => {
    const c = input.value;
    swatch.style.background = c;
    hexEl.textContent = c.toUpperCase();
    state[stateKey] = c;
    updatePreview();
  });
}

function setupMetarelatoControls() {
  metaTitleInput.addEventListener('input', () => { state.metaTitle = metaTitleInput.value; updatePreview(); resetGenerateBtn(); });
  metaBodyInput.addEventListener('input',  () => { state.metaBody  = metaBodyInput.value;  updatePreview(); resetGenerateBtn(); });
  setupMetaColorPicker('metaTitleColorInput', 'metaTitleColorSwatch', 'metaTitleColorHex', 'metaTitleColor');
  setupMetaColorPicker('metaBodyColorInput',  'metaBodyColorSwatch',  'metaBodyColorHex',  'metaBodyColor');

  document.querySelectorAll('.logo-color-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      state.logoColor = btn.dataset.color;
      syncLogoColorBtns();
      updatePreview();
    });
  });

  document.querySelectorAll('.logo-pos-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      state.logoPosition = btn.dataset.pos;
      syncLogoPosBtns();
      updatePreview();
    });
  });
}

// ============================================================
// IMAGE GENERATION
// ============================================================
async function generateImage() {
  if (!state.image) {
    alert('Por favor sube una imagen primero.');
    return;
  }

  generateBtn.disabled = true;
  generateBtn.innerHTML = '<span class="material-symbols-outlined text-lg animate-spin">progress_activity</span><span class="uppercase text-xs tracking-widest">Generando...</span>';

  try {
    await document.fonts.ready;

    const canvas = document.createElement('canvas');
    canvas.width  = 1080;
    canvas.height = 1920;
    const ctx = canvas.getContext('2d');

    // --- Crop coordinates in image space ---
    const { dispW, dispH } = getImageDisplayBounds();
    const { cropW, cropH } = getCropDisplaySize();
    const scaleX = state.imgW / dispW;
    const scaleY = state.imgH / dispH;
    const cropImgX = state.cropOffsetX * scaleX;
    const cropImgY = state.cropOffsetY * scaleY;
    const cropImgW = cropW * scaleX;
    const cropImgH = cropH * scaleY;

    // 1. Draw image with cinematic filter
    ctx.filter = 'contrast(1.1) brightness(0.85)';
    ctx.drawImage(state.image, cropImgX, cropImgY, cropImgW, cropImgH, 0, 0, 1080, 1920);
    ctx.filter = 'none';

    // 2–4. Template-specific overlay
    if (state.activeTemplate === 'metarrelato') {
      const ov = ctx.createLinearGradient(1080, 0, 0, 1920);
      ov.addColorStop(0,    'rgba(0,0,40,0.15)');
      ov.addColorStop(0.30, 'rgba(0,0,40,0.05)');
      ov.addColorStop(0.70, 'rgba(0,0,20,0.55)');
      ov.addColorStop(1.00, 'rgba(0,0,10,0.75)');
      ctx.fillStyle = ov;
      ctx.fillRect(0, 0, 1080, 1920);
    } else {
      // RutaDorada: vignette + cinematic bleed + film grain
      const vigTop = state.align.v === 'top';
      const vig = ctx.createLinearGradient(0, vigTop ? 1920 : 0, 0, vigTop ? 0 : 1920);
      vig.addColorStop(0.25, 'rgba(0,0,0,0)');
      vig.addColorStop(0.50, 'rgba(0,0,0,0.15)');
      vig.addColorStop(0.68, 'rgba(0,0,0,0.70)');
      vig.addColorStop(0.84, 'rgba(0,0,0,0.93)');
      vig.addColorStop(1.00, '#000000');
      ctx.fillStyle = vig;
      ctx.fillRect(0, 0, 1080, 1920);

      const bleed = ctx.createRadialGradient(162, 768, 0, 162, 768, 594);
      bleed.addColorStop(0, 'rgba(180,20,20,0.18)');
      bleed.addColorStop(1, 'rgba(0,0,0,0)');
      ctx.globalCompositeOperation = 'screen';
      ctx.fillStyle = bleed;
      ctx.fillRect(0, 0, 1080, 1920);
      ctx.globalCompositeOperation = 'source-over';

      drawGrain(ctx);
    }

    // 5. Text
    if (state.activeTemplate === 'metarrelato') {
      drawText_metarrelato(ctx, 1080, 1920);
    } else {
      drawText_rutadorada(ctx, 1080, 1920);
    }

    // 6. Download
    canvas.toBlob((blob) => {
      const url  = URL.createObjectURL(blob);
      const link = document.createElement('a');
      link.download = 'miniatura.png';
      link.href = url;
      link.click();
      setTimeout(() => URL.revokeObjectURL(url), 1000);
    }, 'image/png');

  } catch (err) {
    console.error(err);
    alert('Error al generar la imagen: ' + err.message);
  } finally {
    generateBtn.disabled = false;
    generateBtn.innerHTML = '<span class="material-symbols-outlined text-lg">image</span><span class="uppercase text-xs tracking-widest">Generar y descargar</span>';
  }
}

function drawGrain(ctx) {
  const tile = 256;
  const off  = document.createElement('canvas');
  off.width  = tile;
  off.height = tile;
  const octx = off.getContext('2d');
  const id   = octx.createImageData(tile, tile);
  const d    = id.data;
  for (let i = 0; i < d.length; i += 4) {
    const n = Math.floor(Math.random() * 255);
    d[i] = d[i+1] = d[i+2] = n;
    d[i+3] = 255;
  }
  octx.putImageData(id, 0, 0);

  ctx.globalCompositeOperation = 'overlay';
  ctx.globalAlpha = 0.35;
  for (let x = 0; x < 1080; x += tile)
    for (let y = 0; y < 1920; y += tile)
      ctx.drawImage(off, x, y);

  ctx.globalCompositeOperation = 'source-over';
  ctx.globalAlpha = 1;
}

function drawText_rutadorada(ctx, W, H) {
  const { title, titleColor, titleLine2, titleLine2Color, subtitle, subtitleColor, align } = state;
  if (!title && !titleLine2 && !subtitle) return;

  const s = W / 1080;

  const isLeft   = align.h === 'left';
  const isBottom = align.v === 'bottom';

  const PAD_X   = 72  * s;
  const PAD_Y   = 180 * s;
  const T_SIZE  = 196 * s;
  const L2_SIZE = 96  * s;
  const S_SIZE  = 72  * s;
  const T_LH    = T_SIZE * 0.82;
  const T2_GAP  = 6   * s;
  const L2_LH   = L2_SIZE * 0.9;
  const L2_MB   = 28  * s;
  const DIV_H   = 2   * s;
  const DIV_GAP = 24  * s;

  ctx.textAlign = isLeft ? 'left' : 'right';
  const x = isLeft ? PAD_X : (W - PAD_X);

  const setLS = (px) => { try { ctx.letterSpacing = `${px}px`; } catch(e) {} };

  if (isBottom) {
    ctx.textBaseline = 'bottom';
    let y = H - PAD_Y;

    if (subtitle) {
      ctx.font = `900 ${S_SIZE}px "Barlow Condensed"`;
      ctx.fillStyle = subtitleColor;
      setLS(S_SIZE * 0.12);
      ctx.fillText(subtitle.toUpperCase(), x, y);
      y -= S_SIZE;
    }

    y -= DIV_GAP;
    drawDivider(ctx, y, isLeft, PAD_X, DIV_H, W);
    y -= DIV_H;
    y -= L2_MB;

    if (titleLine2) {
      ctx.font = `800 ${L2_SIZE}px "Barlow Condensed"`;
      ctx.fillStyle = titleLine2Color;
      setLS(L2_SIZE * 0.02);
      ctx.fillText(titleLine2.toUpperCase(), x, y);
      y -= L2_LH + T2_GAP;
    }

    if (title) {
      ctx.font = `900 ${T_SIZE}px "Barlow Condensed"`;
      ctx.fillStyle = titleColor;
      setLS(T_SIZE * -0.01);
      ctx.fillText(title.toUpperCase(), x, y);
    }

  } else {
    ctx.textBaseline = 'top';
    let y = PAD_Y;

    if (title) {
      ctx.font = `900 ${T_SIZE}px "Barlow Condensed"`;
      ctx.fillStyle = titleColor;
      setLS(T_SIZE * -0.01);
      ctx.fillText(title.toUpperCase(), x, y);
      y += T_LH + T2_GAP;
    }

    if (titleLine2) {
      ctx.font = `800 ${L2_SIZE}px "Barlow Condensed"`;
      ctx.fillStyle = titleLine2Color;
      setLS(L2_SIZE * 0.02);
      ctx.fillText(titleLine2.toUpperCase(), x, y);
      y += L2_LH;
    }

    y += L2_MB;
    drawDivider(ctx, y, isLeft, PAD_X, DIV_H, W);
    y += DIV_H + DIV_GAP;

    if (subtitle) {
      ctx.font = `900 ${S_SIZE}px "Barlow Condensed"`;
      ctx.fillStyle = subtitleColor;
      setLS(S_SIZE * 0.12);
      ctx.fillText(subtitle.toUpperCase(), x, y);
    }
  }

  try { ctx.letterSpacing = '0px'; } catch(e) {}
}

function wrapText(ctx, text, maxWidth, fontSize, weight, family) {
  ctx.font = `${weight} ${fontSize}px "${family}"`;
  const words = text.split(' ');
  const lines = [];
  let line = '';
  for (const word of words) {
    const test = line ? `${line} ${word}` : word;
    if (ctx.measureText(test).width > maxWidth && line) {
      lines.push(line);
      line = word;
    } else {
      line = test;
    }
  }
  if (line) lines.push(line);
  return lines;
}

function wrapTextNoOrphan(ctx, text, maxWidth, fontSize, weight, family) {
  const lines = wrapText(ctx, text, maxWidth, fontSize, weight, family);
  // If last line is a single word and there's a previous line, absorb it
  if (lines.length >= 2 && lines[lines.length - 1].split(' ').length === 1) {
    const prevWords = lines[lines.length - 2].split(' ');
    const orphan = prevWords.pop();
    if (prevWords.length > 0) {
      lines[lines.length - 2] = prevWords.join(' ');
      lines[lines.length - 1] = orphan + ' ' + lines[lines.length - 1];
    }
  }
  return lines;
}

function drawText_metarrelato(ctx, W, H) {
  const { metaTitle, metaTitleColor, metaBody, metaBodyColor, align, logoColor, logoPosition } = state;
  if (!metaTitle && !metaBody) return;

  const isLeft   = align.h === 'left';
  const isBottom = align.v === 'bottom';
  const PAD_LEFT   = 80;
  const PAD_RIGHT  = 120;
  const PAD_BOTTOM = 160;
  const PAD_TOP    = 50;
  const MAX_W      = W - PAD_LEFT - PAD_RIGHT;
  const TITLE_SIZE = 148;
  const BODY_SIZE  = 44;
  const BODY_LH    = BODY_SIZE * 1.53;
  const GAP        = 16;
  const LOGO_H     = 144;
  const LOGO_PAD   = 80;

  // Draw logo (colorized)
  if (metarrelatoLogo) {
    const ratio  = metarrelatoLogo.naturalWidth / metarrelatoLogo.naturalHeight;
    const logoW  = Math.round(LOGO_H * ratio);
    let logoX, logoY;
    switch (logoPosition) {
      case 'top-right':    logoX = W - LOGO_PAD - logoW; logoY = PAD_TOP;              break;
      case 'bottom-left':  logoX = LOGO_PAD;              logoY = H - LOGO_PAD - LOGO_H; break;
      case 'bottom-right': logoX = W - LOGO_PAD - logoW; logoY = H - LOGO_PAD - LOGO_H; break;
      default:             logoX = LOGO_PAD;              logoY = PAD_TOP;              break; // top-left
    }

    if (logoColor === '#CCFF00') {
      ctx.drawImage(metarrelatoLogo, logoX, logoY, logoW, LOGO_H);
    } else {
      const off = document.createElement('canvas');
      off.width = logoW; off.height = LOGO_H;
      const octx = off.getContext('2d');
      octx.drawImage(metarrelatoLogo, 0, 0, logoW, LOGO_H);
      octx.globalCompositeOperation = 'source-in';
      octx.fillStyle = logoColor;
      octx.fillRect(0, 0, logoW, LOGO_H);
      ctx.drawImage(off, logoX, logoY, logoW, LOGO_H);
    }
  }

  // Text alignment
  const x = isLeft ? PAD_LEFT : (W - PAD_RIGHT);
  ctx.textAlign = isLeft ? 'left' : 'right';

  if (isBottom) {
    ctx.textBaseline = 'bottom';
    let y = H - PAD_BOTTOM;

    if (metaBody) {
      const lines = wrapTextNoOrphan(ctx, metaBody, MAX_W, BODY_SIZE, '400', 'Roboto');
      ctx.font      = `400 ${BODY_SIZE}px "Roboto"`;
      ctx.fillStyle = metaBodyColor;
      try { ctx.letterSpacing = '0.5px'; } catch(e) {}
      for (let i = lines.length - 1; i >= 0; i--) {
        ctx.fillText(lines[i], x, y);
        y -= BODY_LH;
      }
      y -= GAP;
    }

    if (metaTitle) {
      ctx.font      = `900 ${TITLE_SIZE}px "Roboto"`;
      ctx.fillStyle = metaTitleColor;
      try { ctx.letterSpacing = '-2px'; } catch(e) {}
      ctx.fillText(metaTitle.toLowerCase(), x, y);
    }

  } else {
    // Top alignment: title → body
    const logoOffset = (logoPosition === 'top-left' || logoPosition === 'top-right') ? PAD_TOP + LOGO_H + 24 : PAD_TOP;
    ctx.textBaseline = 'top';
    let y = logoOffset;

    if (metaTitle) {
      ctx.font      = `900 ${TITLE_SIZE}px "Roboto"`;
      ctx.fillStyle = metaTitleColor;
      try { ctx.letterSpacing = '-2px'; } catch(e) {}
      ctx.fillText(metaTitle.toLowerCase(), x, y);
      y += TITLE_SIZE * 0.92 + GAP;
    }

    if (metaBody) {
      const lines = wrapTextNoOrphan(ctx, metaBody, MAX_W, BODY_SIZE, '400', 'Roboto');
      ctx.font      = `400 ${BODY_SIZE}px "Roboto"`;
      ctx.fillStyle = metaBodyColor;
      try { ctx.letterSpacing = '0.5px'; } catch(e) {}
      for (const line of lines) {
        ctx.fillText(line, x, y);
        y += BODY_LH;
      }
    }
  }

  try { ctx.letterSpacing = '0px'; } catch(e) {}
}

function drawDivider(ctx, y, isLeft, padX, h, W = 1080) {
  const divW  = W - 2 * padX;
  const x1    = isLeft ? padX : (W - padX);
  const x2    = isLeft ? (padX + divW) : padX;
  const dc    = state.dividerColor;
  const grad  = ctx.createLinearGradient(x1, y, x2, y);
  grad.addColorStop(0,   dc);
  grad.addColorStop(0.5, hexToRgba(dc, 0.2));
  grad.addColorStop(1,   'rgba(0,0,0,0)');
  ctx.fillStyle = grad;
  ctx.fillRect(padX, y, divW, h);
}

// ============================================================
// INIT
function resetGenerateBtn() {
  generateBtn.innerHTML = '<span class="material-symbols-outlined text-lg">image</span><span class="uppercase text-xs tracking-widest">Generar y descargar</span>';
}

// ============================================================
function init() {
  setupUpload();
  setupCropDrag();
  // RutaDorada color pickers
  setupColorPicker('title');
  setupColorPicker('titleLine2');
  setupColorPicker('subtitle');
  setupAlignment();
  setupTemplates();
  setupMetarelatoControls();

  // RutaDorada text inputs
  titleInput.addEventListener('input',     () => { state.title    = titleInput.value;    updatePreview(); resetGenerateBtn(); });
  titleLine2Input.addEventListener('input',() => { state.titleLine2 = titleLine2Input.value; updatePreview(); resetGenerateBtn(); });
  subtitleInput.addEventListener('input',  () => { state.subtitle = subtitleInput.value; updatePreview(); resetGenerateBtn(); });

  generateBtn.addEventListener('click', generateImage);

  window.addEventListener('resize', () => {
    if (state.image) { setupCropRect(); updatePreview(); }
  });
}

// Preload metarrelato logo for canvas rendering
let metarrelatoLogo = null;
(function () {
  const img = new Image();
  img.onload = () => { metarrelatoLogo = img; };
  img.src = '/lienzo/metarrelato-future.svg';
}());

init();
</script>
