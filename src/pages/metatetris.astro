<!DOCTYPE html>
<html lang="es">
<head>
<meta name="robots" content="noindex, nofollow"/>
<meta charset="utf-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover"/>
<meta name="theme-color" content="#0d0a24"/>
<meta name="apple-mobile-web-app-capable" content="yes"/>
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent"/>
<title>metatetris — salvapantallas de 8 bits</title>
<meta name="description" content="Un salvapantallas de tetris estilo 8 bits que juega solo. Toca una tecla para tomar el control."/>
<link rel="icon" type="image/svg+xml" href="/metatetris/metatetris.svg"/>
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
<link href="https://fonts.googleapis.com/css2?family=Press+Start+2P&display=swap" rel="stylesheet"/>
<style is:inline>
  * { margin: 0; padding: 0; -webkit-box-sizing: border-box; box-sizing: border-box; }
  html, body { height: 100%; }
  body {
    background-color: #150e33;
    color: #ffffff;
    font-family: 'Press Start 2P', 'Courier New', monospace;
    overflow: hidden;
    -webkit-user-select: none;
    -moz-user-select: none;
    -ms-user-select: none;
    user-select: none;
    -webkit-text-size-adjust: 100%;
    -webkit-tap-highlight-color: rgba(0,0,0,0);
  }
  button { font-family: inherit; color: inherit; cursor: pointer; }
  button:focus { outline: 2px solid #ffcf35; outline-offset: 2px; }

  #app { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background-color: #150e33; }

  /* decorative layers */
  #vignette {
    position: absolute; top: 0; left: 0; right: 0; bottom: 0;
    pointer-events: none; z-index: 3;
    box-shadow: inset 0 0 140px rgba(0, 0, 0, 0.6);
  }
  #scanlines {
    position: absolute; top: 0; left: 0; right: 0; bottom: 0;
    pointer-events: none; z-index: 3; opacity: 0.14;
    background-image: -webkit-repeating-linear-gradient(top, rgba(0,0,0,0.9) 0px, rgba(0,0,0,0.9) 1px, transparent 1px, transparent 4px);
    background-image: repeating-linear-gradient(to bottom, rgba(0,0,0,0.9) 0px, rgba(0,0,0,0.9) 1px, transparent 1px, transparent 4px);
  }

  /* header */
  #hdr { position: absolute; top: 0; left: 0; right: 0; height: 64px; padding: 14px 16px; z-index: 5; }
  #cloudLogo { display: inline-block; vertical-align: middle; }
  #hdr h1 {
    display: inline-block; vertical-align: middle;
    margin-left: 14px;
    font-size: 17px; font-weight: normal;
    color: #f43f5e;
    letter-spacing: 2px;
    text-shadow: 3px 3px 0 #4a0d1e;
  }
  #fsBtn {
    position: absolute; top: 13px; right: 14px; z-index: 9;
    font-size: 8px; letter-spacing: 1px;
    color: #ffffff; background-color: #0b0721;
    border: 3px solid #4636a3;
    padding: 10px 12px;
    box-shadow: 4px 4px 0 #000000;
  }
  #fsBtn:active { box-shadow: 1px 1px 0 #000000; }

  /* stage */
  #stage { position: absolute; top: 64px; bottom: 38px; left: 0; right: 0; z-index: 4; }
  #frame {
    position: absolute; left: 50%; top: 50%;
    -webkit-transform: translate(-50%, -50%);
    -ms-transform: translate(-50%, -50%);
    transform: translate(-50%, -50%);
    text-align: center;
  }
  #boardWrap {
    position: relative; display: inline-block; vertical-align: top;
    background-color: #0b0721;
    border: 4px solid #4636a3;
    box-shadow: 8px 8px 0 rgba(0, 0, 0, 0.45);
  }
  #board { display: block; }

  /* overlay over the board */
  #overlay {
    position: absolute; top: 0; left: 0; right: 0; bottom: 0;
    display: none; z-index: 6; width: 100%; height: 100%;
  }
  #overlay.dim { background-color: rgba(5, 3, 16, 0.72); }
  #overlay .cell { display: table; width: 100%; height: 100%; }
  #overlay .mid { display: table-cell; vertical-align: middle; text-align: center; }
  #ovTitle { font-size: 14px; color: #ffcf35; text-shadow: 2px 2px 0 #000000; letter-spacing: 2px; line-height: 1.8; }
  #ovSub { font-size: 8px; color: #ffffff; margin-top: 14px; letter-spacing: 1px; line-height: 1.9; }

  /* side panel */
  #panel { display: inline-block; vertical-align: top; margin-left: 18px; text-align: left; }
  .pbox {
    background-color: #0b0721;
    border: 3px solid #372a6e;
    padding: 10px 12px;
    margin-bottom: 12px;
    min-width: 148px;
  }
  .pbox .lbl { font-size: 8px; color: #8f86c9; letter-spacing: 1px; margin-bottom: 9px; }
  .pbox .val { font-size: 12px; letter-spacing: 1px; }
  #vScore { color: #ffcf35; }
  #vLevel { color: #2fd4e6; }
  #vLines { color: #43d34f; }
  #vTop   { color: #ff9426; }
  #next { display: block; margin: 0 auto; }

  /* stacked layout (narrow screens) */
  body.stack #panel { display: block; margin: 8px 0 0 0; text-align: center; white-space: nowrap; }
  body.stack .pbox { display: inline-block; vertical-align: top; min-width: 0; margin: 0 2px; padding: 6px 5px; }
  body.stack .pbox .lbl { font-size: 6px; margin-bottom: 5px; }
  body.stack .pbox .val { font-size: 8px; letter-spacing: 0; }

  /* status bar */
  #status {
    position: absolute; bottom: 0; left: 0; right: 0; height: 38px;
    line-height: 38px; text-align: center; z-index: 5;
    font-size: 8px; color: #8f86c9; letter-spacing: 1px;
    white-space: nowrap; overflow: hidden;
  }

  /* touch pad */
  #pad { position: absolute; bottom: 42px; left: 0; right: 0; text-align: center; display: none; z-index: 8; }
  .padbtn {
    display: inline-block;
    min-width: 54px; padding: 18px 8px;
    margin: 0 2px;
    font-size: 10px; letter-spacing: 0;
    color: #ffffff; background-color: rgba(11, 7, 33, 0.9);
    border: 3px solid #4636a3;
    box-shadow: 3px 3px 0 #000000;
    text-align: center;
  }
  .padbtn:active { box-shadow: 1px 1px 0 #000000; background-color: #251a5e; }

  /* blink */
  @-webkit-keyframes blinkstep { 0%, 54% { opacity: 1; } 55%, 100% { opacity: 0; } }
  @keyframes blinkstep { 0%, 54% { opacity: 1; } 55%, 100% { opacity: 0; } }
  .blink {
    -webkit-animation: blinkstep 1.1s step-end infinite;
    animation: blinkstep 1.1s step-end infinite;
  }
  @media (prefers-reduced-motion: reduce) {
    .blink { -webkit-animation: none; animation: none; }
    #scanlines { display: none; }
  }

  /* zen (fake fullscreen) hides chrome but keeps the button */
  body.zen #hdr h1, body.zen #cloudLogo, body.zen #status { visibility: hidden; }

  @media (max-width: 620px) {
    #hdr { height: 48px; padding: 12px 10px; }
    #hdr h1 { font-size: 10px; margin-left: 8px; letter-spacing: 1px; text-shadow: 2px 2px 0 #4a0d1e; }
    #cloudLogo { width: 36px; height: 22px; }
    #fsBtn { top: 8px; right: 8px; padding: 8px 8px; font-size: 7px; }
    #stage { top: 48px; }
    #ovTitle { font-size: 10px; }
    #ovSub { font-size: 7px; }
    #status { font-size: 6px; }
  }

  #noscript-msg { padding: 90px 20px; text-align: center; font-size: 10px; line-height: 2; color: #ffffff; }
</style>
</head>
<body>
<div id="app">
  <div id="hdr">
    <svg id="cloudLogo" viewBox="0 0 20 12" width="52" height="31" shape-rendering="crispEdges" aria-hidden="true"><rect x="11" y="0" width="5" height="1" fill="#f43f5e"/><rect x="10" y="1" width="7" height="1" fill="#f43f5e"/><rect x="3" y="2" width="3" height="1" fill="#f43f5e"/><rect x="9" y="2" width="9" height="1" fill="#f43f5e"/><rect x="2" y="3" width="16" height="1" fill="#f43f5e"/><rect x="1" y="4" width="18" height="1" fill="#f43f5e"/><rect x="0" y="5" width="20" height="1" fill="#f43f5e"/><rect x="0" y="6" width="20" height="1" fill="#f43f5e"/><rect x="0" y="7" width="20" height="1" fill="#f43f5e"/><rect x="0" y="8" width="20" height="1" fill="#f43f5e"/><rect x="0" y="9" width="20" height="1" fill="#f43f5e"/><rect x="1" y="10" width="18" height="1" fill="#f43f5e"/><rect x="2" y="11" width="16" height="1" fill="#c9284d"/><g id="eyesOpen"><rect x="3" y="5" width="2" height="1" fill="#ffffff"/><rect x="7" y="5" width="2" height="1" fill="#ffffff"/><rect x="3" y="6" width="1" height="1" fill="#ffffff"/><rect x="7" y="6" width="1" height="1" fill="#ffffff"/></g><g id="eyesClosed" style="display:none"><rect x="3" y="6" width="2" height="1" fill="#ffffff"/><rect x="7" y="6" width="2" height="1" fill="#ffffff"/></g></svg>
    <h1>METATETRIS</h1>
  </div>
  <button id="fsBtn" type="button" aria-label="Pantalla completa">FULLSCREEN</button>

  <div id="stage">
    <div id="frame">
      <div id="boardWrap">
        <canvas id="board" role="img" aria-label="Tablero de tetris"></canvas>
        <div id="overlay">
          <div class="cell"><div class="mid">
            <div id="ovTitle" class="blink">DEMO PLAY</div>
            <div id="ovSub"></div>
          </div></div>
        </div>
      </div>
      <div id="panel">
        <div class="pbox"><div class="lbl">NEXT</div><canvas id="next"></canvas></div>
        <div class="pbox"><div class="lbl">SCORE</div><div class="val" id="vScore">000000</div></div>
        <div class="pbox"><div class="lbl">LEVEL</div><div class="val" id="vLevel">00</div></div>
        <div class="pbox"><div class="lbl">LINES</div><div class="val" id="vLines">000</div></div>
        <div class="pbox"><div class="lbl">TOP</div><div class="val" id="vTop">000000</div></div>
      </div>
    </div>
  </div>

  <div id="pad">
    <button class="padbtn" type="button" id="padL" aria-label="Mover a la izquierda">&lt;</button>
    <button class="padbtn" type="button" id="padRot" aria-label="Rotar">ROT</button>
    <button class="padbtn" type="button" id="padR" aria-label="Mover a la derecha">&gt;</button>
    <button class="padbtn" type="button" id="padD" aria-label="Bajar">v</button>
    <button class="padbtn" type="button" id="padDrop" aria-label="Caída instantánea">DRP</button>
  </div>

  <div id="status">SCREENSAVER MODE &#183; PRESS ANY KEY OR TAP TO PLAY</div>

  <div id="scanlines"></div>
  <div id="vignette"></div>

  <noscript><div id="noscript-msg">METATETRIS NECESITA JAVASCRIPT PARA FUNCIONAR.</div></noscript>
</div>

<script is:inline>
(function () {
  'use strict';

  /* ================= constants ================= */
  var COLS = 10, ROWS = 20;
  var CLEAR_MS = 320;      /* line flash duration */
  var AI_TICK = 130;       /* ms between AI moves */
  var SOFT_MS = 45;        /* gravity while soft-dropping */
  var DEMO_GRAV = 380;     /* screensaver: calm constant fall */
  var DEMO_SOFT = 150;     /* screensaver: gentle glide once aligned */
  var READY_TIMEOUT = 12000;
  var PLAY_TIMEOUT = 40000;
  var PAUSE_TIMEOUT = 60000;
  var OVER_TIMEOUT = 12000;

  /* [base, light, dark] per piece; index 0 unused */
  var PALETTE = [
    null,
    ['#2fd4e6', '#8ff0fa', '#17808f'],  /* I cyan   */
    ['#ffcf35', '#ffe98c', '#b8860e'],  /* O yellow */
    ['#9d5cf0', '#c9a0ff', '#5f2e9e'],  /* T purple */
    ['#43d34f', '#93eb9b', '#1f8a2a'],  /* S green  */
    ['#ff5c3c', '#ff9d85', '#b02c14'],  /* Z red    */
    ['#3f7bf6', '#92b4ff', '#1f47a8'],  /* J blue   */
    ['#ff9426', '#ffc275', '#b55c0a']   /* L orange */
  ];
  var LEVEL_COLORS = ['#4636a3', '#17808f', '#1f8a2a', '#b8860e', '#b55c0a', '#b02c14', '#5f2e9e', '#1f47a8'];

  /* rotations as flat [x0,y0,x1,y1,x2,y2,x3,y3] inside a 4x4 box */
  var PIECES = [
    [[0,1,1,1,2,1,3,1], [2,0,2,1,2,2,2,3]],                                        /* I */
    [[1,0,2,0,1,1,2,1]],                                                           /* O */
    [[1,0,0,1,1,1,2,1], [1,0,1,1,2,1,1,2], [0,1,1,1,2,1,1,2], [1,0,0,1,1,1,1,2]],  /* T */
    [[1,0,2,0,0,1,1,1], [1,0,1,1,2,1,2,2]],                                        /* S */
    [[0,0,1,0,1,1,2,1], [2,0,1,1,2,1,1,2]],                                        /* Z */
    [[0,0,0,1,1,1,2,1], [1,0,2,0,1,1,1,2], [0,1,1,1,2,1,2,2], [1,0,1,1,0,2,1,2]],  /* J */
    [[2,0,0,1,1,1,2,1], [1,0,1,1,1,2,2,2], [0,1,1,1,2,1,0,2], [0,0,1,0,1,1,1,2]]   /* L */
  ];
  var SPEEDS = [800, 720, 630, 550, 470, 380, 300, 220, 130, 100, 80, 80, 80, 70, 70, 70, 60, 60, 60, 50];

  /* ================= dom ================= */
  function $(id) { return document.getElementById(id); }
  var board = $('board'), next = $('next');
  var bctx = board.getContext('2d'), nctx = next.getContext('2d');
  var stage = $('stage'), boardWrap = $('boardWrap');
  var overlay = $('overlay'), ovTitle = $('ovTitle'), ovSub = $('ovSub');
  var statusBar = $('status'), fsBtn = $('fsBtn');
  var vScore = $('vScore'), vLevel = $('vLevel'), vLines = $('vLines'), vTop = $('vTop');
  var eyesOpen = $('eyesOpen'), eyesClosed = $('eyesClosed');
  var pad = $('pad');

  var isTouch = ('ontouchstart' in window);
  var reducedMotion = false;
  try {
    reducedMotion = !!(window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches);
  } catch (err) {}

  /* ================= state ================= */
  var mode = 'demo';   /* demo | ready | play | pause | over */
  var cell = 24, nextCell = 14, dpr = 1;
  var lastActivity = now();
  var mouseX = null, mouseY = null, mouseDist = 0;
  var softDrop = false;
  var topScore = 0;
  try { topScore = parseInt(window.localStorage.getItem('metatetris.top'), 10) || 0; } catch (err) {}

  var game = null;
  var bag = [];
  var aiPlan = null, aiTimer = 0, aiStuck = 0;
  var demoOverT = 0;   /* pause after a demo game over before restarting */

  function now() { return new Date().getTime(); }

  /* ================= game core ================= */
  function newGrid() {
    var g = [], y, x, row;
    for (y = 0; y < ROWS; y++) { row = []; for (x = 0; x < COLS; x++) row.push(0); g.push(row); }
    return g;
  }

  function refillBag() {
    var pool = [0, 1, 2, 3, 4, 5, 6], i, j, t;
    for (i = pool.length - 1; i > 0; i--) {
      j = Math.floor(Math.random() * (i + 1));
      t = pool[i]; pool[i] = pool[j]; pool[j] = t;
    }
    bag = pool;
  }
  function takeType() { if (!bag.length) refillBag(); return bag.pop(); }

  function newGame() {
    refillBag();
    game = {
      grid: newGrid(),
      piece: null,
      nextType: takeType(),
      score: 0, lines: 0, level: 0,
      over: false,
      clearing: null, clearT: 0,
      gravAcc: 0
    };
    softDrop = false;
    spawn();
  }

  function spawn() {
    game.piece = { t: game.nextType, r: 0, x: 3, y: -2 };
    game.nextType = takeType();
    aiPlan = null; aiStuck = 0;
    if (collides(game.piece.t, game.piece.r, game.piece.x, game.piece.y + 1) &&
        collides(game.piece.t, game.piece.r, game.piece.x, game.piece.y)) {
      endGame();
    }
    drawNext();
  }

  function collides(t, r, px, py) {
    var s = PIECES[t][r], i, cx, cy;
    for (i = 0; i < 8; i += 2) {
      cx = px + s[i]; cy = py + s[i + 1];
      if (cx < 0 || cx >= COLS || cy >= ROWS) return true;
      if (cy >= 0 && game.grid[cy][cx]) return true;
    }
    return false;
  }

  function move(dx) {
    var p = game.piece;
    if (!p || game.clearing) return false;
    if (!collides(p.t, p.r, p.x + dx, p.y)) { p.x += dx; return true; }
    return false;
  }

  function rotate() {
    var p = game.piece;
    if (!p || game.clearing) return false;
    var nr = (p.r + 1) % PIECES[p.t].length;
    var kicks = [0, -1, 1, -2, 2], i;
    for (i = 0; i < kicks.length; i++) {
      if (!collides(p.t, nr, p.x + kicks[i], p.y)) { p.r = nr; p.x += kicks[i]; return true; }
    }
    return false;
  }

  function stepDown(points) {
    var p = game.piece;
    if (!p || game.clearing) return false;
    if (!collides(p.t, p.r, p.x, p.y + 1)) {
      p.y++;
      if (points) game.score += points;
      return true;
    }
    lockPiece();
    return false;
  }

  function hardDrop() {
    var p = game.piece;
    if (!p || game.clearing) return;
    while (!collides(p.t, p.r, p.x, p.y + 1)) { p.y++; game.score += 2; }
    lockPiece();
  }

  function lockPiece() {
    var p = game.piece, s = PIECES[p.t][p.r], i, cx, cy, above = false;
    for (i = 0; i < 8; i += 2) {
      cx = p.x + s[i]; cy = p.y + s[i + 1];
      if (cy < 0) { above = true; continue; }
      game.grid[cy][cx] = p.t + 1;
    }
    game.piece = null;
    softDrop = false;
    if (above) { endGame(); return; }
    var full = fullRows();
    if (full.length) {
      game.clearing = full; game.clearT = CLEAR_MS;
    } else {
      spawn();
    }
    syncHud();
  }

  function fullRows() {
    var rows = [], y, x, full;
    for (y = 0; y < ROWS; y++) {
      full = true;
      for (x = 0; x < COLS; x++) if (!game.grid[y][x]) { full = false; break; }
      if (full) rows.push(y);
    }
    return rows;
  }

  function collapseRows() {
    var rows = game.clearing, i, y;
    for (i = 0; i < rows.length; i++) {
      game.grid.splice(rows[i], 1);
      var blank = []; for (y = 0; y < COLS; y++) blank.push(0);
      game.grid.unshift(blank);
    }
    var n = rows.length;
    var base = [0, 40, 100, 300, 1200][n] || 0;
    game.score += base * (game.level + 1);
    game.lines += n;
    game.level = Math.floor(game.lines / 10);
    game.clearing = null;
    spawn();
    syncHud();
  }

  function endGame() {
    game.over = true;
    game.piece = null;
    if (mode === 'play') {
      if (game.score > topScore) {
        topScore = game.score;
        try { window.localStorage.setItem('metatetris.top', String(topScore)); } catch (err) {}
      }
      setMode('over');
    } else {
      demoOverT = 1800;
      showOverlay(true, 'GAME OVER', '', false);
    }
    syncHud();
  }

  function gravityMs() {
    if (mode !== 'play') return softDrop ? DEMO_SOFT : DEMO_GRAV; /* relaxed screensaver pace */
    var lv = game.level;
    var base = (lv < SPEEDS.length) ? SPEEDS[lv] : 50;
    return softDrop ? Math.min(SOFT_MS, base) : base;
  }

  /* ================= demo AI ================= */
  function planBest() {
    var p = game.piece, rots = PIECES[p.t], best = null;
    var r, x, y, i, score;
    for (r = 0; r < rots.length; r++) {
      for (x = -2; x < COLS; x++) {
        if (collides(p.t, r, x, 0) && collides(p.t, r, x, -2)) continue;
        y = -2;
        if (collides(p.t, r, x, y)) continue;
        while (!collides(p.t, r, x, y + 1)) y++;
        score = evalDrop(p.t, r, x, y);
        if (best === null || score > best.score) best = { r: r, x: x, score: score };
      }
    }
    return best;
  }

  function evalDrop(t, r, px, py) {
    /* copy grid, place piece, measure */
    var g = [], y, x, i;
    for (y = 0; y < ROWS; y++) g.push(game.grid[y].slice(0));
    var s = PIECES[t][r];
    for (i = 0; i < 8; i += 2) {
      var cy = py + s[i + 1];
      if (cy < 0) return -1e9; /* would lock above the board */
      g[cy][px + s[i]] = 1;
    }
    var linesCleared = 0, full;
    for (y = 0; y < ROWS; y++) {
      full = true;
      for (x = 0; x < COLS; x++) if (!g[y][x]) { full = false; break; }
      if (full) { linesCleared++; g.splice(y, 1); var blank = []; for (x = 0; x < COLS; x++) blank.push(0); g.unshift(blank); }
    }
    var heights = [], holes = 0, agg = 0, bump = 0;
    for (x = 0; x < COLS; x++) {
      var h = 0, seen = false;
      for (y = 0; y < ROWS; y++) {
        if (g[y][x]) { if (!seen) { seen = true; h = ROWS - y; } }
        else if (seen) holes++;
      }
      heights.push(h); agg += h;
    }
    for (x = 0; x < COLS - 1; x++) bump += Math.abs(heights[x] - heights[x + 1]);
    return -0.510066 * agg + 0.760666 * linesCleared - 0.35663 * holes - 0.184483 * bump;
  }

  function aiAct() {
    if (!game.piece || game.clearing || game.over) return;
    if (!aiPlan) { aiPlan = planBest(); aiStuck = 0; if (!aiPlan) { softDrop = true; return; } }
    var p = game.piece, ok;
    if (p.r !== aiPlan.r) ok = rotate();
    else if (p.x < aiPlan.x) ok = move(1);
    else if (p.x > aiPlan.x) ok = move(-1);
    else { softDrop = true; return; }
    if (!ok) {
      aiStuck++;
      if (aiStuck > 4) softDrop = true; /* give up steering, let it fall */
    }
  }

  /* ================= modes / ui ================= */
  function setMode(m) {
    mode = m;
    lastActivity = now();
    softDrop = false;
    if (m === 'demo' || m === 'play') newGame();
    syncUi();
    relayout();
  }

  function syncUi() {
    var touchHint = isTouch ? 'TAP TO PLAY' : 'PRESS ANY KEY OR TAP TO PLAY';
    if (mode === 'demo') {
      showOverlay(false, 'DEMO PLAY', '', true);
      statusBar.innerHTML = 'SCREENSAVER MODE &#183; ' + touchHint;
    } else if (mode === 'ready') {
      showOverlay(true, 'PLAYER 1', isTouch ? 'TAP TO START' : 'PRESS ANY KEY TO START', true);
      statusBar.innerHTML = 'GET READY';
    } else if (mode === 'play') {
      hideOverlay();
      statusBar.innerHTML = isTouch
        ? 'GOOD LUCK, PLAYER 1'
        : '&#8592;&#8594; MOVE &#183; &#8593; ROTATE &#183; &#8595; DOWN &#183; SPACE DROP &#183; P PAUSE';
    } else if (mode === 'pause') {
      showOverlay(true, 'PAUSE', isTouch ? 'TAP TO RESUME' : 'PRESS P TO RESUME', false);
      statusBar.innerHTML = 'PAUSED';
    } else if (mode === 'over') {
      showOverlay(true, 'GAME OVER', 'SCORE ' + pad6(game.score) + '<br/>' + (isTouch ? 'TAP TO RETRY' : 'PRESS ENTER TO RETRY'), false);
      statusBar.innerHTML = 'GAME OVER';
    }
    pad.style.display = (isTouch && (mode === 'play' || mode === 'pause')) ? 'block' : 'none';
    syncHud();
  }

  function showOverlay(dim, title, sub, blinkTitle) {
    overlay.style.display = 'block';
    overlay.className = dim ? 'dim' : '';
    ovTitle.innerHTML = title;
    ovTitle.className = (blinkTitle && !reducedMotion) ? 'blink' : '';
    ovSub.innerHTML = sub;
    ovSub.style.display = sub ? 'block' : 'none';
  }
  function hideOverlay() { overlay.style.display = 'none'; }

  function pad6(n) { var s = '000000' + n; return (n > 999999) ? String(n) : s.slice(s.length - 6); }
  function padN(n, w) { var s = '00000' + n; return s.slice(s.length - w); }

  function syncHud() {
    vScore.innerHTML = pad6(game.score);
    vLevel.innerHTML = padN(game.level, 2);
    vLines.innerHTML = padN(game.lines, 3);
    vTop.innerHTML = pad6(topScore);
    boardWrap.style.borderColor = LEVEL_COLORS[game.level % LEVEL_COLORS.length];
  }

  /* ================= input ================= */
  function wake() {
    lastActivity = now();
    if (mode === 'demo') setMode('ready');
  }

  document.addEventListener('mousemove', function (e) {
    if (mouseX !== null) mouseDist += Math.abs(e.clientX - mouseX) + Math.abs(e.clientY - mouseY);
    mouseX = e.clientX; mouseY = e.clientY;
    if (mouseDist > 12) { mouseDist = 0; wake(); }
    lastActivity = now();
  }, false);

  document.addEventListener('keydown', function (e) {
    var k = e.keyCode;
    if (k === 32 || (k >= 37 && k <= 40)) {
      if (e.preventDefault) e.preventDefault();
    }
    lastActivity = now();
    if (mode === 'demo') { setMode('ready'); return; }
    if (mode === 'ready') { setMode('play'); return; }
    if (mode === 'over') { if (k === 13 || k === 32) setMode('play'); return; }
    if (mode === 'pause') { if (k === 80 || k === 27 || k === 13) setMode2('play'); return; }
    if (mode !== 'play' || !game || game.over) return;
    if (k === 37 || k === 65) move(-1);
    else if (k === 39 || k === 68) move(1);
    else if (k === 38 || k === 87) rotate();
    else if (k === 40 || k === 83) { softDrop = true; game.gravAcc = gravityMs(); }
    else if (k === 32) hardDrop();
    else if (k === 80 || k === 27) setMode2('pause');
  }, false);

  document.addEventListener('keyup', function (e) {
    var k = e.keyCode;
    if (k === 40 || k === 83) softDrop = false;
  }, false);

  /* pause/resume without resetting the game */
  function setMode2(m) {
    mode = m;
    lastActivity = now();
    syncUi();
  }

  function stageTap(e) {
    lastActivity = now();
    if (mode === 'demo') { setMode('ready'); prevent(e); return; }
    if (mode === 'ready') { setMode('play'); prevent(e); return; }
    if (mode === 'over') { setMode('play'); prevent(e); return; }
    if (mode === 'pause') { setMode2('play'); prevent(e); return; }
  }
  function prevent(e) { if (e && e.preventDefault) e.preventDefault(); }

  if (isTouch) stage.addEventListener('touchstart', stageTap, false);
  stage.addEventListener('mousedown', stageTap, false);

  /* touch pad buttons: fire on press, repeat while held */
  function bindHold(el, fn, repeat) {
    var timer = null;
    function start(e) {
      prevent(e);
      lastActivity = now();
      if (mode === 'pause') { setMode2('play'); return; }
      if (mode !== 'play' || !game || game.over) return;
      fn();
      if (repeat) timer = setInterval(function () {
        if (mode === 'play') fn(); else stop();
      }, 110);
    }
    function stop() { if (timer) { clearInterval(timer); timer = null; } }
    el.addEventListener('touchstart', start, false);
    el.addEventListener('touchend', stop, false);
    el.addEventListener('touchcancel', stop, false);
  }
  bindHold($('padL'), function () { move(-1); }, true);
  bindHold($('padR'), function () { move(1); }, true);
  bindHold($('padRot'), function () { rotate(); }, false);
  bindHold($('padD'), function () { stepDown(1); }, true);
  bindHold($('padDrop'), function () { hardDrop(); }, false);

  window.addEventListener('blur', function () {
    if (mode === 'play') setMode2('pause');
  }, false);

  /* ================= fullscreen ================= */
  function fsElement() {
    return document.fullscreenElement || document.webkitFullscreenElement ||
           document.mozFullScreenElement || document.msFullscreenElement || null;
  }
  function toggleFullscreen() {
    var el = document.documentElement;
    if (fsElement()) {
      var exit = document.exitFullscreen || document.webkitExitFullscreen ||
                 document.mozCancelFullScreen || document.msExitFullscreen;
      if (exit) exit.call(document);
      return;
    }
    var req = el.requestFullscreen || el.webkitRequestFullscreen ||
              el.mozRequestFullScreen || el.msRequestFullscreen;
    if (req) {
      req.call(el);
    } else {
      /* no fullscreen API (old iOS): zen mode hides the chrome */
      var cls = document.body.className;
      if (cls.indexOf('zen') === -1) {
        document.body.className = cls + ' zen';
        fsBtn.innerHTML = 'EXIT';
      } else {
        document.body.className = cls.replace(/\s*zen/, '');
        fsBtn.innerHTML = 'FULLSCREEN';
      }
      relayout();
    }
  }
  function onFsChange() {
    fsBtn.innerHTML = fsElement() ? 'EXIT' : 'FULLSCREEN';
    relayout();
  }
  fsBtn.addEventListener('click', function (e) {
    if (e.stopPropagation) e.stopPropagation();
    lastActivity = now();
    toggleFullscreen();
  }, false);
  document.addEventListener('fullscreenchange', onFsChange, false);
  document.addEventListener('webkitfullscreenchange', onFsChange, false);
  document.addEventListener('mozfullscreenchange', onFsChange, false);
  document.addEventListener('MSFullscreenChange', onFsChange, false);

  /* ================= layout / render ================= */
  function relayout() {
    dpr = Math.min(window.devicePixelRatio || 1, 2);
    /* the touch pad gets real room: raise the stage instead of overlapping it */
    stage.style.bottom = (isTouch && (mode === 'play' || mode === 'pause')) ? '116px' : '38px';
    var w = stage.clientWidth - 16, h = stage.clientHeight - 16;
    var stack = w < 520;
    document.body.className = document.body.className.replace(/\s*stack/, '') + (stack ? ' stack' : '');
    if (stack) {
      cell = Math.floor(Math.min((w - 10) / COLS, (h - 72) / ROWS));
    } else {
      cell = Math.floor(Math.min((h - 8) / ROWS, (w - 190) / COLS));
    }
    if (cell < 8) cell = 8;
    if (cell > 42) cell = 42;
    nextCell = Math.max(8, Math.floor(cell * (stack ? 0.5 : 0.62)));

    board.style.width = (cell * COLS) + 'px';
    board.style.height = (cell * ROWS) + 'px';
    board.width = cell * COLS * dpr;
    board.height = cell * ROWS * dpr;
    bctx.scale(dpr, dpr);

    next.style.width = (nextCell * 4) + 'px';
    next.style.height = (nextCell * 3) + 'px';
    next.width = nextCell * 4 * dpr;
    next.height = nextCell * 3 * dpr;
    nctx.scale(dpr, dpr);

    draw();
    drawNext();
  }

  function drawCell(ctx, px, py, size, colorIdx, flash) {
    if (flash) {
      ctx.fillStyle = '#ffffff';
      ctx.fillRect(px, py, size, size);
      return;
    }
    var p = PALETTE[colorIdx];
    if (!p) return;
    var e = Math.max(2, Math.floor(size / 6));
    ctx.fillStyle = p[0];
    ctx.fillRect(px, py, size, size);
    ctx.fillStyle = p[1];
    ctx.fillRect(px, py, size, e);
    ctx.fillRect(px, py, e, size);
    ctx.fillStyle = p[2];
    ctx.fillRect(px, py + size - e, size, e);
    ctx.fillRect(px + size - e, py, e, size);
  }

  function draw() {
    if (!game) return;
    var w = cell * COLS, h = cell * ROWS, x, y;
    bctx.fillStyle = '#0b0721';
    bctx.fillRect(0, 0, w, h);
    /* faint grid */
    bctx.fillStyle = '#180f3f';
    for (x = 1; x < COLS; x++) bctx.fillRect(x * cell, 0, 1, h);
    for (y = 1; y < ROWS; y++) bctx.fillRect(0, y * cell, w, 1);
    /* stack */
    var flashOn = game.clearing && (Math.floor(game.clearT / 80) % 2 === 0);
    for (y = 0; y < ROWS; y++) {
      var isClearing = game.clearing && arrHas(game.clearing, y);
      for (x = 0; x < COLS; x++) {
        if (game.grid[y][x]) drawCell(bctx, x * cell, y * cell, cell, game.grid[y][x], isClearing && flashOn);
      }
    }
    /* current piece */
    var p = game.piece;
    if (p) {
      var s = PIECES[p.t][p.r], i;
      for (i = 0; i < 8; i += 2) {
        var cy = p.y + s[i + 1];
        if (cy >= 0) drawCell(bctx, (p.x + s[i]) * cell, cy * cell, cell, p.t + 1, false);
      }
    }
  }

  function arrHas(arr, v) {
    for (var i = 0; i < arr.length; i++) if (arr[i] === v) return true;
    return false;
  }

  function drawNext() {
    if (!game) return;
    var w = nextCell * 4, h = nextCell * 3;
    nctx.fillStyle = '#0b0721';
    nctx.fillRect(0, 0, w, h);
    var t = game.nextType, s = PIECES[t][0], i;
    var minX = 4, maxX = 0, minY = 4, maxY = 0;
    for (i = 0; i < 8; i += 2) {
      if (s[i] < minX) minX = s[i];
      if (s[i] > maxX) maxX = s[i];
      if (s[i + 1] < minY) minY = s[i + 1];
      if (s[i + 1] > maxY) maxY = s[i + 1];
    }
    var offX = (w - (maxX - minX + 1) * nextCell) / 2 - minX * nextCell;
    var offY = (h - (maxY - minY + 1) * nextCell) / 2 - minY * nextCell;
    for (i = 0; i < 8; i += 2) {
      drawCell(nctx, offX + s[i] * nextCell, offY + s[i + 1] * nextCell, nextCell, t + 1, false);
    }
  }

  /* ================= main loop ================= */
  var rafNative = window.requestAnimationFrame || window.webkitRequestAnimationFrame || null;
  function raf(cb) {
    if (rafNative) rafNative.call(window, cb);
    else window.setTimeout(cb, 16);
  }
  var lastT = now();

  function loop() {
    var t = now(), dt = t - lastT;
    lastT = t;
    if (dt > 250) dt = 250;
    var running = (mode === 'demo' || mode === 'ready' || mode === 'play');

    if (running && game) {
      if (game.over) {
        /* demo game over: brief pause, then a fresh demo game */
        if (mode !== 'play') {
          demoOverT -= dt;
          if (demoOverT <= 0) { newGame(); syncUi(); }
        }
      } else if (game.clearing) {
        game.clearT -= dt;
        if (game.clearT <= 0) collapseRows();
      } else if (game.piece) {
        if (mode !== 'play') {
          aiTimer += dt;
          while (aiTimer >= AI_TICK) { aiTimer -= AI_TICK; aiAct(); }
        }
        game.gravAcc += dt;
        var g = gravityMs();
        while (game.gravAcc >= g && game.piece && !game.clearing) {
          game.gravAcc -= g;
          stepDown((mode === 'play' && softDrop) ? 1 : 0);
          g = gravityMs();
        }
      }
      draw();
    }
    raf(loop);
  }

  /* housekeeping: return to screensaver after inactivity */
  window.setInterval(function () {
    var idle = now() - lastActivity;
    if (mode === 'ready' && idle > READY_TIMEOUT) setMode('demo');
    else if (mode === 'play' && idle > PLAY_TIMEOUT) setMode('demo');
    else if (mode === 'pause' && idle > PAUSE_TIMEOUT) setMode('demo');
    else if (mode === 'over' && idle > OVER_TIMEOUT) setMode('demo');
  }, 1000);

  /* the cloud blinks */
  if (!reducedMotion) {
    window.setInterval(function () {
      eyesOpen.style.display = 'none';
      eyesClosed.style.display = 'block';
      window.setTimeout(function () {
        eyesOpen.style.display = 'block';
        eyesClosed.style.display = 'none';
      }, 160);
    }, 4200);
  }

  window.addEventListener('resize', relayout, false);
  window.addEventListener('orientationchange', function () {
    window.setTimeout(relayout, 250);
  }, false);

  /* ================= start ================= */
  if (isTouch) document.body.className += ' touch';
  newGame();
  syncUi();
  relayout();
  raf(loop);
})();
</script>
</body>
</html>
