<!DOCTYPE html>
<html lang="es">
<head>
<meta name="robots" content="noindex, nofollow"/>
<meta charset="utf-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover"/>
<meta name="theme-color" content="#f9f9fa"/>
<title>conversor — Precios en pesos, en tu moneda</title>
<link rel="icon" type="image/svg+xml" href="/conversor/conversor.svg"/>
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@1,500;1,600&family=Barlow+Condensed:wght@600;700&family=Manrope:wght@400;500;600;700&display=swap" rel="stylesheet"/>
<script is:inline src="https://cdn.jsdelivr.net/npm/tesseract.js@5.1.1/dist/tesseract.min.js"></script>
<style is:inline>
  :root {
    --surface: #f9f9fa;
    --surface-card: #ffffff;
    --on-surface: #1a1c1d;
    --muted: #717881;
    --line: #c0c7d2;
    --primary: #F06071;
    --primary-dark: #c93050;
    --on-primary: #ffffff;
    --glass: rgba(249, 249, 250, 0.88);
    --glass-line: rgba(26, 28, 29, 0.1);
  }
  * { margin: 0; padding: 0; box-sizing: border-box; }
  html, body { height: 100%; }
  body {
    background: var(--surface);
    color: var(--on-surface);
    font-family: 'Manrope', system-ui, sans-serif;
    -webkit-font-smoothing: antialiased;
    touch-action: manipulation;
    overflow: hidden;
  }
  button { font: inherit; color: inherit; background: none; border: none; cursor: pointer; }
  button:focus-visible, a:focus-visible { outline: 2px solid var(--primary); outline-offset: 2px; }

  /* ---------- Pantalla de inicio ---------- */
  #start {
    height: 100dvh;
    overflow-y: auto;
    display: flex;
    flex-direction: column;
    padding: calc(env(safe-area-inset-top) + 2.2rem) 1.6rem calc(env(safe-area-inset-bottom) + 1.4rem);
    max-width: 30rem;
    margin: 0 auto;
  }
  .wordmark { display: flex; align-items: center; gap: 0.45rem; }
  .wordmark img { width: 2.1rem; height: 2.1rem; }
  .wordmark span {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-style: italic;
    font-weight: 500;
    font-size: 2rem;
    letter-spacing: -0.03em;
    line-height: 1;
    color: var(--on-surface);
  }
  #start h1 {
    font-weight: 500;
    font-size: 1.05rem;
    line-height: 1.65;
    color: var(--on-surface);
    margin-top: 1.6rem;
  }
  #start h1 strong { color: var(--primary-dark); font-weight: 700; }
  .rates-card {
    margin-top: 1.8rem;
    border: 1px solid var(--line);
    border-radius: 0.9rem;
    background: var(--surface-card);
    padding: 1.1rem 1.2rem;
  }
  .rates-card h2 {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 0.7rem;
  }
  .rate-row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding: 0.42rem 0;
    border-bottom: 1px solid #e2e2e3;
    font-size: 0.92rem;
  }
  .rate-row:last-of-type { border-bottom: none; }
  .rate-row b {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 700;
    font-size: 1.15rem;
    letter-spacing: 0.02em;
    color: var(--primary);
  }
  .rates-note { margin-top: 0.6rem; font-size: 0.72rem; color: var(--muted); line-height: 1.5; }
  #ratesError { margin-top: 1.8rem; font-size: 0.88rem; line-height: 1.6; color: var(--on-surface); display: none; }
  #ratesError button { color: var(--primary-dark); font-weight: 700; text-decoration: underline; padding: 0; }

  #openBtn {
    margin-top: 1.8rem;
    width: 100%;
    padding: 0.95rem 1rem;
    border-radius: 0.75rem;
    background: var(--primary);
    color: var(--on-primary);
    font-weight: 700;
    font-size: 1rem;
    box-shadow: 0 4px 14px rgba(240, 96, 113, 0.35);
    transition: transform 0.15s ease, opacity 0.15s ease;
  }
  #openBtn:active { transform: scale(0.98); }
  #openBtn:disabled { opacity: 0.45; cursor: default; box-shadow: none; }
  .start-notes { margin-top: 1.4rem; display: grid; gap: 0.55rem; }
  .start-notes p {
    font-size: 0.78rem;
    color: var(--muted);
    line-height: 1.55;
    padding-left: 1rem;
    position: relative;
  }
  .start-notes p::before { content: '·'; position: absolute; left: 0.2rem; color: var(--primary); font-weight: 700; }
  .start-footer {
    margin-top: auto;
    padding-top: 2rem;
    font-size: 0.72rem;
    color: var(--muted);
  }
  .start-footer a { color: var(--muted); }

  /* ---------- Vista de cámara ---------- */
  #live { position: fixed; inset: 0; display: none; background: #000; }
  #live.on { display: block; }
  #cam { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; }
  #overlay { position: absolute; inset: 0; overflow: hidden; }

  .mark {
    position: absolute;
    border: 2px solid var(--primary);
    border-radius: 4px;
    box-shadow: 0 0 0 1px rgba(255, 255, 255, 0.4);
    transition: opacity 0.5s ease;
  }
  .tag {
    position: absolute;
    transform: translateY(-50%);
    background: var(--primary);
    color: var(--on-primary);
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 700;
    letter-spacing: 0.02em;
    line-height: 1.15;
    padding: 3px 10px 4px;
    border-radius: 6px;
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.35);
    white-space: nowrap;
    transition: opacity 0.5s ease;
  }
  .tag::before {
    content: '';
    position: absolute;
    left: -6px;
    top: 50%;
    transform: translateY(-50%);
    border: 5px solid transparent;
    border-left: none;
    border-right: 6px solid var(--primary);
  }
  .tag.flip::before {
    left: auto;
    right: -6px;
    border-right: none;
    border-left: 6px solid var(--primary);
  }
  .tag.below { transform: none; }
  .tag.below::before {
    left: 12px;
    right: auto;
    top: -6px;
    transform: none;
    border: 5px solid transparent;
    border-top: none;
    border-bottom: 6px solid var(--primary);
  }
  .fade { opacity: 0; }

  .ping {
    position: absolute;
    width: 46px;
    height: 46px;
    margin: -23px 0 0 -23px;
    border-radius: 50%;
    border: 3px solid var(--primary);
    animation: ping 0.9s ease-out infinite;
    pointer-events: none;
  }
  @keyframes ping {
    0% { transform: scale(0.4); opacity: 1; }
    100% { transform: scale(1.15); opacity: 0.25; }
  }

  .toast {
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
    bottom: calc(env(safe-area-inset-bottom) + 4.6rem);
    background: var(--glass);
    -webkit-backdrop-filter: blur(16px);
    backdrop-filter: blur(16px);
    border: 1px solid var(--glass-line);
    border-radius: 999px;
    padding: 0.55rem 1rem;
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--on-surface);
    white-space: nowrap;
    transition: opacity 0.4s ease;
  }

  .topbar {
    position: absolute;
    top: 0; left: 0; right: 0;
    padding: calc(env(safe-area-inset-top) + 0.7rem) 0.7rem 0.5rem;
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 0.5rem;
  }
  .pill {
    background: var(--glass);
    -webkit-backdrop-filter: blur(16px);
    backdrop-filter: blur(16px);
    border: 1px solid var(--glass-line);
    border-radius: 999px;
    padding: 0.48rem 0.8rem;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.01em;
    color: var(--on-surface);
    white-space: nowrap;
  }
  .picker { position: relative; min-width: 0; }
  #curBtn { display: flex; align-items: center; gap: 0.4rem; max-width: 100%; }
  #curBtn .dot { width: 6px; height: 6px; border-radius: 50%; background: var(--primary); flex-shrink: 0; }
  #curBtn .lbl { overflow: hidden; text-overflow: ellipsis; }
  #curBtn svg { flex-shrink: 0; opacity: 0.7; }
  #curMenu {
    position: absolute;
    top: calc(100% + 0.4rem);
    right: 0;
    background: var(--glass);
    -webkit-backdrop-filter: blur(20px);
    backdrop-filter: blur(20px);
    border: 1px solid var(--glass-line);
    border-radius: 0.8rem;
    padding: 0.3rem;
    display: none;
    flex-direction: column;
    min-width: 15rem;
    z-index: 10;
    box-shadow: 0 6px 24px rgba(26, 28, 29, 0.18);
  }
  #curMenu.open { display: flex; }
  #curMenu button {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 0.8rem;
    padding: 0.65rem 0.75rem;
    border-radius: 0.55rem;
    font-size: 0.8rem;
    font-weight: 600;
    text-align: left;
    color: var(--on-surface);
  }
  #curMenu button:active { background: rgba(240, 96, 113, 0.12); }
  #curMenu button .check { color: var(--primary); font-weight: 700; visibility: hidden; }
  #curMenu button[aria-checked="true"] .check { visibility: visible; }

  .bottombar {
    position: absolute;
    bottom: 0; left: 0; right: 0;
    padding: 0.5rem 0.7rem calc(env(safe-area-inset-bottom) + 0.8rem);
    display: flex;
    justify-content: center;
    pointer-events: none;
  }
  .bottombar .pill {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    max-width: 100%;
    pointer-events: auto;
  }
  #scanDot {
    width: 7px; height: 7px;
    border-radius: 50%;
    background: var(--line);
    flex-shrink: 0;
  }
  #scanDot.busy { background: var(--primary); animation: pulse 1.1s ease-in-out infinite; }
  @keyframes pulse { 50% { opacity: 0.25; } }
  #status { overflow: hidden; text-overflow: ellipsis; }
  #rateLine { color: var(--muted); border-left: 1px solid var(--glass-line); padding-left: 0.6rem; white-space: nowrap; }

  /* ---------- Pantalla de error ---------- */
  #errScreen {
    position: fixed;
    inset: 0;
    background: var(--surface);
    display: none;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    text-align: center;
    padding: 2rem 1.8rem;
    gap: 0.9rem;
    z-index: 20;
  }
  #errScreen.on { display: flex; }
  #errScreen h2 { font-size: 1.1rem; font-weight: 700; }
  #errScreen p { font-size: 0.88rem; color: var(--muted); line-height: 1.65; max-width: 24rem; }
  #errScreen button {
    margin-top: 0.6rem;
    padding: 0.75rem 2rem;
    border-radius: 0.75rem;
    background: var(--primary);
    color: var(--on-primary);
    font-weight: 700;
  }

  @media (prefers-reduced-motion: reduce) {
    * { animation: none !important; transition: none !important; }
  }
</style>
</head>
<body>

<!-- Pantalla de inicio -->
<main id="start">
  <div class="wordmark">
    <img src="/conversor/conversor.svg" alt=""/>
    <span>conversor</span>
  </div>
  <h1>Apunta la cámara a un precio en <strong>pesos mexicanos</strong>, tócalo en la pantalla y mira cuánto cuesta en dólares, euros o reales, con el tipo de cambio de hoy.</h1>

  <section class="rates-card" id="ratesCard" hidden>
    <h2>Tipo de cambio de hoy</h2>
    <div class="rate-row"><span>1 dólar (USD)</span><b id="rUSD">—</b></div>
    <div class="rate-row"><span>1 euro (EUR)</span><b id="rEUR">—</b></div>
    <div class="rate-row"><span>1 real (BRL)</span><b id="rBRL">—</b></div>
    <p class="rates-note" id="ratesNote"></p>
  </section>
  <p id="ratesError">No se pudo obtener el tipo de cambio. Revisa tu conexión a internet. <button id="retryRates">Reintentar</button></p>

  <button id="openBtn" disabled>Cargando tipo de cambio…</button>

  <div class="start-notes">
    <p>Toca el precio en la pantalla y verás junto a él la conversión, por ejemplo: $210 = R$62.17.</p>
    <p>Detecta los precios que llevan el símbolo $ antes del número.</p>
    <p>Todo ocurre en tu teléfono: las imágenes no se envían a ningún servidor.</p>
  </div>

  <p class="start-footer">Una herramienta de <a href="https://metarrelato.com">metarrelato</a></p>
</main>

<!-- Vista de cámara -->
<div id="live">
  <video id="cam" playsinline muted autoplay></video>
  <div id="overlay"></div>

  <header class="topbar">
    <div class="pill">MXN - Pesos mexicanos</div>
    <div class="picker">
      <button id="curBtn" class="pill" aria-haspopup="listbox" aria-expanded="false">
        <span class="dot"></span>
        <span class="lbl" id="curLbl"></span>
        <svg width="10" height="6" viewBox="0 0 10 6" fill="none"><path d="M1 1l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
      </button>
      <div id="curMenu" role="listbox"></div>
    </div>
  </header>

  <footer class="bottombar">
    <div class="pill">
      <span id="scanDot"></span>
      <span id="status">Preparando el lector…</span>
      <span id="rateLine"></span>
    </div>
  </footer>
</div>

<!-- Pantalla de error -->
<div id="errScreen">
  <h2 id="errTitle"></h2>
  <p id="errMsg"></p>
  <button id="errBtn">Reintentar</button>
</div>

<script is:inline>
(function () {
  'use strict';

  var $ = function (id) { return document.getElementById(id); };
  var LS_RATES = 'conversor:rates';
  var LS_CUR = 'conversor:currency';

  var CURRENCIES = {
    USD: { label: 'USD - United States dollars', format: function (v) { return '$' + fmtNum(v); } },
    EUR: { label: 'EUR - Euros', format: function (v) { return fmtNum(v) + ' €'; } },
    BRL: { label: 'BRL - Reais brasileiros', format: function (v) { return 'R$' + fmtNum(v); } }
  };
  var CUR_ORDER = ['USD', 'EUR', 'BRL'];

  var rates = null;        // { date, rates: {USD, EUR, BRL}, fetchedDay, stale }
  var currency = localStorage.getItem(LS_CUR);
  if (!CURRENCIES[currency]) currency = 'USD';

  var worker = null;
  var workerReady = false;
  var workerFailed = false;
  var liveOn = false;
  var reading = false;
  var stream = null;
  var results = [];        // etiquetas visibles: { value, tag }

  var video = $('cam');
  var overlay = $('overlay');
  var live = $('live');
  var crop = document.createElement('canvas');
  var cropCtx = crop.getContext('2d', { willReadFrequently: true });

  function fmtNum(v) {
    return v.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
  }

  function fmtMXN(v) {
    if (v % 1 === 0) return '$' + v.toLocaleString('en-US');
    return '$' + fmtNum(v);
  }

  function fmtDateEs(iso) {
    try {
      return new Date(iso + 'T12:00:00').toLocaleDateString('es-MX', { day: 'numeric', month: 'long', year: 'numeric' });
    } catch (e) { return iso; }
  }

  /* ---------- Tipo de cambio ---------- */

  function todayKey() { return new Date().toISOString().slice(0, 10); }

  function readCachedRates() {
    try { return JSON.parse(localStorage.getItem(LS_RATES) || 'null'); } catch (e) { return null; }
  }

  function loadRates() {
    var cached = readCachedRates();
    if (cached && cached.fetchedDay === todayKey()) {
      rates = cached;
      onRatesReady();
      return;
    }
    fetch('https://api.frankfurter.dev/v1/latest?base=MXN&symbols=USD,EUR,BRL')
      .then(function (r) { if (!r.ok) throw new Error('HTTP ' + r.status); return r.json(); })
      .then(function (data) {
        rates = { date: data.date, rates: data.rates, fetchedDay: todayKey(), stale: false };
        try { localStorage.setItem(LS_RATES, JSON.stringify(rates)); } catch (e) {}
        onRatesReady();
      })
      .catch(function () {
        if (cached) {
          rates = cached;
          rates.stale = true;
          onRatesReady();
        } else {
          $('ratesError').style.display = 'block';
          $('openBtn').textContent = 'Sin tipo de cambio';
        }
      });
  }

  function onRatesReady() {
    $('ratesError').style.display = 'none';
    $('ratesCard').hidden = false;
    CUR_ORDER.forEach(function (c) {
      $('r' + c).textContent = '$' + fmtNum(1 / rates.rates[c]) + ' MXN';
    });
    var note = 'Tipo de cambio del ' + fmtDateEs(rates.date) + ' · Banco Central Europeo';
    if (rates.stale) note = 'Sin conexión: usando el ' + note.charAt(0).toLowerCase() + note.slice(1);
    $('ratesNote').textContent = note;
    $('openBtn').disabled = false;
    $('openBtn').textContent = 'Abrir cámara';
    updateRateLine();
  }

  function updateRateLine() {
    if (!rates) return;
    $('rateLine').textContent = '1 ' + currency + ' = $' + fmtNum(1 / rates.rates[currency]);
  }

  /* ---------- Selector de moneda ---------- */

  function buildCurrencyMenu() {
    var menu = $('curMenu');
    menu.innerHTML = '';
    CUR_ORDER.forEach(function (c) {
      var b = document.createElement('button');
      b.setAttribute('role', 'option');
      b.setAttribute('aria-checked', c === currency ? 'true' : 'false');
      var name = document.createElement('span');
      name.textContent = CURRENCIES[c].label;
      var check = document.createElement('span');
      check.className = 'check';
      check.textContent = '✓';
      b.appendChild(name);
      b.appendChild(check);
      b.addEventListener('click', function () {
        currency = c;
        try { localStorage.setItem(LS_CUR, c); } catch (e) {}
        $('curLbl').textContent = CURRENCIES[c].label;
        buildCurrencyMenu();
        toggleMenu(false);
        updateRateLine();
        refreshResultTags();
      });
      menu.appendChild(b);
    });
    $('curLbl').textContent = CURRENCIES[currency].label;
  }

  function toggleMenu(open) {
    var menu = $('curMenu');
    var willOpen = typeof open === 'boolean' ? open : !menu.classList.contains('open');
    menu.classList.toggle('open', willOpen);
    $('curBtn').setAttribute('aria-expanded', String(willOpen));
  }

  $('curBtn').addEventListener('click', function (e) { e.stopPropagation(); toggleMenu(); });
  document.addEventListener('click', function () { toggleMenu(false); });

  /* ---------- Lector de texto (OCR) ---------- */

  function initWorker() {
    if (worker || workerFailed || typeof Tesseract === 'undefined') {
      if (typeof Tesseract === 'undefined') workerFailed = true;
      return;
    }
    Tesseract.createWorker('eng', 1, {
      logger: function (m) {
        if (m.progress != null && !workerReady && liveOn) {
          $('status').textContent = 'Preparando el lector… ' + Math.round(m.progress * 100) + '%';
        }
      }
    }).then(function (w) {
      worker = w;
      return w.setParameters({ tessedit_pageseg_mode: '11' }); // texto disperso: precios sueltos en menús y carteles
    }).then(function () {
      workerReady = true;
      if (liveOn) $('status').textContent = 'Toca un precio con $';
    }).catch(function () {
      workerFailed = true;
      if (liveOn) showError('No se pudo cargar el lector', 'Revisa tu conexión a internet y vuelve a intentar.');
    });
  }

  function parseAmount(s) {
    s = s.replace(/[.,]+$/, '');
    var lc = s.lastIndexOf(','), ld = s.lastIndexOf('.');
    if (lc > -1 && ld > -1) {
      if (lc > ld) s = s.replace(/\./g, '').replace(',', '.');
      else s = s.replace(/,/g, '');
    } else if (lc > -1) {
      if (s.length - lc - 1 === 2 && s.indexOf(',') === lc) s = s.replace(',', '.');
      else s = s.replace(/,/g, '');
    }
    var v = parseFloat(s);
    return isFinite(v) && v > 0 && v < 100000000 ? v : null;
  }

  function sameLine(a, b) {
    var overlap = Math.min(a.y1, b.y1) - Math.max(a.y0, b.y0);
    return overlap > 0.5 * Math.min(a.y1 - a.y0, b.y1 - b.y0) && (b.x0 - a.x1) < 2.5 * (a.y1 - a.y0);
  }

  function extractPrices(words) {
    var out = [];
    var MIN_CONF = 30;
    for (var i = 0; i < words.length; i++) {
      var w = words[i];
      if (!w || !w.bbox || (w.confidence || 0) < MIN_CONF) continue;
      var t = (w.text || '').trim();
      var m = t.match(/\$\s*(\d[\d.,]*)/);
      if (m) {
        var v = parseAmount(m[1]);
        if (v != null) out.push({ value: v, bbox: w.bbox });
        continue;
      }
      // "$" separado del número: "$" + "120"
      if (/\$$/.test(t) && words[i + 1] && (words[i + 1].confidence || 0) >= MIN_CONF) {
        var nx = (words[i + 1].text || '').trim().match(/^(\d[\d.,]*)/);
        if (nx && sameLine(w.bbox, words[i + 1].bbox)) {
          var v2 = parseAmount(nx[1]);
          if (v2 != null) {
            var b2 = words[i + 1].bbox;
            out.push({ value: v2, bbox: { x0: w.bbox.x0, y0: Math.min(w.bbox.y0, b2.y0), x1: b2.x1, y1: Math.max(w.bbox.y1, b2.y1) } });
            i++;
          }
        }
      }
    }
    return out;
  }

  /* ---------- Cámara ---------- */

  function openCamera() {
    var btn = $('openBtn');
    btn.disabled = true;
    btn.textContent = 'Abriendo cámara…';
    navigator.mediaDevices.getUserMedia({
      audio: false,
      video: { facingMode: { ideal: 'environment' }, width: { ideal: 1920 }, height: { ideal: 1080 } }
    }).then(function (s) {
      stream = s;
      video.srcObject = s;
      return video.play();
    }).then(function () {
      $('start').style.display = 'none';
      live.classList.add('on');
      liveOn = true;
      if (workerReady) $('status').textContent = 'Toca un precio con $';
      else initWorker();
    }).catch(function () {
      btn.disabled = false;
      btn.textContent = 'Abrir cámara';
      showError('No hay acceso a la cámara', 'Actívala en los permisos de tu navegador para este sitio y vuelve a intentar.');
    });
  }

  /* ---------- Tocar para convertir ---------- */

  function coverMap() {
    var dw = live.clientWidth, dh = live.clientHeight;
    var vw = video.videoWidth, vh = video.videoHeight;
    var s = Math.max(dw / vw, dh / vh);
    return { s: s, dx: (dw - vw * s) / 2, dy: (dh - vh * s) / 2, dw: dw, dh: dh, vw: vw, vh: vh };
  }

  function clamp(v, lo, hi) { return Math.max(lo, Math.min(hi, v)); }

  function onTap(e) {
    if ($('curMenu').classList.contains('open')) { toggleMenu(false); return; }
    if (reading || !liveOn || !video.videoWidth) return;
    if (!workerReady) {
      if (!workerFailed) showToast('El lector aún se está preparando…');
      return;
    }

    var tapX = e.clientX, tapY = e.clientY;
    var m = coverMap();
    var vx = (tapX - m.dx) / m.s;
    var vy = (tapY - m.dy) / m.s;

    // recorte alrededor del dedo, ampliado para leer mejor
    var cw = Math.round(clamp(m.vw * 0.5, 320, m.vw));
    var ch = Math.round(clamp(cw * 0.45, 200, m.vh));
    var sx = Math.round(clamp(vx - cw / 2, 0, m.vw - cw));
    var sy = Math.round(clamp(vy - ch / 2, 0, m.vh - ch));
    var up = clamp(900 / cw, 1, 3);
    crop.width = Math.round(cw * up);
    crop.height = Math.round(ch * up);
    cropCtx.drawImage(video, sx, sy, cw, ch, 0, 0, crop.width, crop.height);

    reading = true;
    $('scanDot').classList.add('busy');
    $('status').textContent = 'Leyendo…';
    var ping = document.createElement('div');
    ping.className = 'ping';
    ping.style.left = tapX + 'px';
    ping.style.top = tapY + 'px';
    overlay.appendChild(ping);

    var tx = (vx - sx) * up;
    var ty = (vy - sy) * up;

    worker.recognize(crop).then(function (res) {
      var prices = extractPrices((res.data && res.data.words) || []);
      var best = null, bestD = Infinity;
      prices.forEach(function (p) {
        var cx = (p.bbox.x0 + p.bbox.x1) / 2;
        var cy = (p.bbox.y0 + p.bbox.y1) / 2;
        var inside = tx >= p.bbox.x0 && tx <= p.bbox.x1 && ty >= p.bbox.y0 && ty <= p.bbox.y1;
        var d = inside ? 0 : Math.hypot(cx - tx, cy - ty);
        if (d < bestD) { bestD = d; best = p; }
      });
      var maxD = 0.35 * Math.hypot(crop.width, crop.height);
      if (best && bestD <= maxD) {
        showResult(best, { sx: sx, sy: sy, up: up, map: m });
      } else {
        showToast('No leí un precio con $ ahí. Acércate e intenta de nuevo.');
      }
    }).catch(function () {
      showToast('No se pudo leer. Intenta de nuevo.');
    }).then(function () {
      ping.remove();
      reading = false;
      $('scanDot').classList.remove('busy');
      $('status').textContent = 'Toca un precio con $';
    });
  }

  overlay.addEventListener('pointerdown', onTap);

  /* ---------- Resultados sobre el video ---------- */

  function tagText(value) {
    return fmtMXN(value) + ' = ' + CURRENCIES[currency].format(value * rates.rates[currency]);
  }

  function showResult(p, ctx) {
    // del recorte de vuelta a coordenadas de pantalla
    var x = (ctx.sx + p.bbox.x0 / ctx.up) * ctx.map.s + ctx.map.dx;
    var y = (ctx.sy + p.bbox.y0 / ctx.up) * ctx.map.s + ctx.map.dy;
    var w = ((p.bbox.x1 - p.bbox.x0) / ctx.up) * ctx.map.s;
    var h = ((p.bbox.y1 - p.bbox.y0) / ctx.up) * ctx.map.s;

    var mark = document.createElement('div');
    mark.className = 'mark';
    mark.style.left = (x - 3) + 'px';
    mark.style.top = (y - 3) + 'px';
    mark.style.width = (w + 6) + 'px';
    mark.style.height = (h + 6) + 'px';
    overlay.appendChild(mark);

    var tag = document.createElement('div');
    tag.className = 'tag';
    tag.textContent = tagText(p.value);
    tag.style.fontSize = clamp(h * 0.85, 16, 30) + 'px';
    tag.style.left = (x + w + 10) + 'px';
    tag.style.top = (y + h / 2) + 'px';
    overlay.appendChild(tag);

    if (x + w + 10 + tag.offsetWidth > ctx.map.dw - 4) {
      var flippedLeft = x - tag.offsetWidth - 10;
      if (flippedLeft >= 4) {
        tag.classList.add('flip');
        tag.style.left = flippedLeft + 'px';
      } else {
        tag.classList.add('below');
        tag.style.left = clamp(x, 4, ctx.map.dw - tag.offsetWidth - 4) + 'px';
        tag.style.top = (y + h + 10) + 'px';
      }
    }

    var entry = { value: p.value, tag: tag };
    results.push(entry);
    setTimeout(function () {
      mark.classList.add('fade');
      tag.classList.add('fade');
      setTimeout(function () {
        mark.remove();
        tag.remove();
        results = results.filter(function (r) { return r !== entry; });
      }, 550);
    }, 6000);
  }

  function refreshResultTags() {
    if (!rates) return;
    results.forEach(function (r) { r.tag.textContent = tagText(r.value); });
  }

  var toastEl = null;
  function showToast(msg) {
    if (toastEl) toastEl.remove();
    toastEl = document.createElement('div');
    toastEl.className = 'toast';
    toastEl.textContent = msg;
    live.appendChild(toastEl);
    var el = toastEl;
    setTimeout(function () { el.classList.add('fade'); }, 2200);
    setTimeout(function () { el.remove(); if (toastEl === el) toastEl = null; }, 2700);
  }

  /* ---------- Errores y ciclo de vida ---------- */

  function showError(title, msg) {
    $('errTitle').textContent = title;
    $('errMsg').textContent = msg;
    $('errScreen').classList.add('on');
  }

  $('errBtn').addEventListener('click', function () { location.reload(); });
  $('retryRates').addEventListener('click', function () {
    $('ratesError').style.display = 'none';
    $('openBtn').textContent = 'Cargando tipo de cambio…';
    loadRates();
  });
  $('openBtn').addEventListener('click', function () {
    if (!navigator.mediaDevices || !navigator.mediaDevices.getUserMedia) {
      showError('Cámara no disponible', 'Tu navegador no permite usar la cámara desde una página web. Prueba con Safari o Chrome en tu celular.');
      return;
    }
    openCamera();
  });

  window.addEventListener('pagehide', function () {
    if (stream) stream.getTracks().forEach(function (t) { t.stop(); });
  });

  /* ---------- Arranque ---------- */

  buildCurrencyMenu();
  loadRates();
  if ('requestIdleCallback' in window) requestIdleCallback(initWorker, { timeout: 4000 });
  else setTimeout(initWorker, 1500);
})();
</script>
</body>
</html>
